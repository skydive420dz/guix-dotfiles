tmp=$(mktemp -d "${TMPDIR:-/tmp}/sk-guix-build-gate-check.XXXXXX")
tmp=$(CDPATH='' cd "$tmp" && pwd -P)
cleanup() {
    rm -rf -- "$tmp"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

fail() {
    printf 'FAIL: %s\n' "$1" >&2
    exit 1
}

contains() {
    case $1 in
        *"$2"*) ;;
        *) fail "expected output to contain: $2" ;;
    esac
}

lacks() {
    case $1 in
        *"$2"*) fail "expected output to omit: $2" ;;
        *) ;;
    esac
}

