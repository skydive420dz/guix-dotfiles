#!/bin/sh

set -eu

repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)
tmp=$(mktemp -d "${TMPDIR:-/tmp}/sk-guix-build-gate-check.XXXXXX")
tmp=$(CDPATH='' cd "$tmp" && pwd -P)
cleanup() {
    rm -rf -- "$tmp"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

fail() {
    printf 'FAIL: %s\n' "$1" >&2
    exit 1
}

contains() {
    case $1 in
        *"$2"*) ;;
        *) fail "expected output to contain: $2" ;;
    esac
}

sandbox_repo=$tmp/repo
sandbox_home=$tmp/home
fake_profile=$tmp/time-machine-profile
fake_system=$tmp/fake-system
fake_home=$tmp/fake-home
fake_system_manifest=$tmp/fake-system-installed
fake_home_manifest=$tmp/fake-home-installed
fake_recovery_names=$tmp/fake-recovery-names
fake_home_names=$tmp/fake-home-names
fake_log=$tmp/guix.log
gate=$sandbox_repo/scripts/guix-build-gate
fake_guix=$sandbox_home/.config/guix/current/bin/guix
fake_guile=$sandbox_home/bin/guile

mkdir -p "$sandbox_repo/scripts" "$sandbox_repo/guix/home" \
    "$sandbox_repo/guix/systems" "$sandbox_repo/guix/manifests" \
    "$sandbox_repo/guix/modules/sk" "$sandbox_repo/fixtures/racket" \
    "$(dirname "$fake_guix")" "$(dirname "$fake_guile")" \
    "$fake_profile/bin" "$fake_system/profile/bin" \
    "$fake_system/profile/share/emacs/site-lisp/exwm-0.35" \
    "$fake_home/profile/bin" "$fake_home/profile/share/fish/functions" \
    "$fake_home/files/.config/fish"
cp "$repo/scripts/guix-build-gate" "$gate"
cp "$repo/guix/package-ownership.scm" \
    "$sandbox_repo/guix/package-ownership.scm"
chmod +x "$gate"
printf '%s\n' '(home-environment)' >"$sandbox_repo/guix/home/guixpc.scm"
printf '%s\n' '(operating-system)' >"$sandbox_repo/guix/systems/guixpc.scm"
printf '%s\n' '(define-module (sk development-tiers))' \
    >"$sandbox_repo/guix/modules/sk/development-tiers.scm"
for manifest in core-lisp jvm-lisp racket; do
    printf '(manifest %s)\n' "$manifest" \
        >"$sandbox_repo/guix/manifests/$manifest.scm"
done
printf '%s\n' '#lang racket/base' \
    >"$sandbox_repo/fixtures/racket/basic-test.rkt"

for command in bluetoothctl curl dbus-update-activation-environment emacs fish \
    git kitty picom reset rg startx vim xrandr xset xwallpaper; do
    printf '%s\n' '#!/bin/sh' 'exit 0' \
        >"$fake_system/profile/bin/$command"
    chmod +x "$fake_system/profile/bin/$command"
done

write_fake_fish() {
    cat >"$fake_system/profile/bin/fish" <<'EOF'
#!/bin/sh
set -eu
[ "${1:-}" = --no-config ]
[ "${2:-}" = --command ]
[ -n "${3:-}" ]
[ -r "${SK_FISH_CONFIG:?}" ]
[ "${SSH_CONNECTION:?}" = build-gate ]
[ "$PATH" = "$SK_FAKE_SYSTEM/profile/bin" ]
[ -L "$HOME/.guix-home" ]
[ -r "$HOME/.profile" ]
[ -r "${XDG_RUNTIME_DIR:?}/on-first-login-executed" ]
exit "${SK_FAKE_FISH_STATUS:-0}"
EOF
    chmod +x "$fake_system/profile/bin/fish"
}

write_fake_fish

for command in bat btop chafa chromium clang emacs fastfetch fzf gcc gdb \
    guile jq lua lua-language-server make mediainfo pamixer pipemixer pylsp \
    ranger ruff sbcl shellcheck shfmt; do
    printf '%s\n' '#!/bin/sh' 'exit 0' >"$fake_home/profile/bin/$command"
    chmod +x "$fake_home/profile/bin/$command"
done
for library in geiser-0 geiser-guile-0 org-0 sly-0 use-package-0; do
    mkdir -p "$fake_home/profile/share/emacs/site-lisp/$library"
done
printf '%s\n' 'function fenv' 'end' \
    >"$fake_home/profile/share/fish/functions/fenv.fish"
printf '%s\n' 'function fenv.main' 'end' \
    >"$fake_home/profile/share/fish/functions/fenv.main.fish"
printf '%s\n' '# fake generated Fish config' \
    >"$fake_home/files/.config/fish/config.fish"
printf '%s\n' '# fake generated profile' >"$fake_home/files/.profile"

printf '%s\n' curl git fish emacs emacs-exwm bluez ncurses ripgrep vim \
    xset xwallpaper picom xrandr >"$fake_recovery_names"
printf '%s\n' fish-foreign-env emacs emacs-desktop-environment emacs-geiser \
    emacs-sly guile sbcl lua-language-server python-lsp-server \
    ungoogled-chromium ranger shellcheck >"$fake_home_names"

write_fake_manifest() {
    output=$1
    shift
    : >"$output"
    for package in "$@"; do
        printf '%s\t1\tout\t/gnu/store/fake-%s\n' "$package" "$package" \
            >>"$output"
    done
}

remove_fake_manifest_package() {
    manifest=$1
    package=$2
    awk -v package="$package" '$1 != package { print }' "$manifest" \
        >"$manifest.new"
    mv "$manifest.new" "$manifest"
}

replace_fake_manifest_path() {
    manifest=$1
    package=$2
    path=$3
    awk -v package="$package" -v path="$path" '
        BEGIN { OFS = "\t" }
        $1 == package { $4 = path }
        { print }
    ' "$manifest" >"$manifest.new"
    mv "$manifest.new" "$manifest"
}

write_fake_manifest "$fake_system_manifest" \
    bluez curl emacs emacs-exwm fish git guile kitty-latest ncurses picom \
    ripgrep vim xrandr xset xwallpaper
write_fake_manifest "$fake_home_manifest" \
    emacs emacs-desktop-environment emacs-geiser emacs-sly fish \
    fish-foreign-env guile lua-language-server python-lsp-server ranger sbcl \
    shellcheck ungoogled-chromium

write_channels() {
    guix_commit=${1:-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa}
    cat >"$sandbox_repo/guix/channels.scm" <<EOF
(list
 (channel
  (name 'guix)
  (commit "$guix_commit")
  (introduction
   (make-channel-introduction
    "1111111111111111111111111111111111111111"
    (openpgp-fingerprint "AAAA"))))
 (channel
  (name 'nonguix)
  (commit "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb")
  (introduction
   (make-channel-introduction
    "2222222222222222222222222222222222222222"
    (openpgp-fingerprint "BBBB"))))
 (channel
  (name 'sk-guix)
  (commit "cccccccccccccccccccccccccccccccccccccccc")
  (introduction
   (make-channel-introduction
    "3333333333333333333333333333333333333333"
    (openpgp-fingerprint "CCCC")))))
EOF
}

write_channels

cat >"$fake_guile" <<'EOF'
#!/bin/sh
set -eu
case ${4:-} in
    %guixpc-recovery-package-specifications)
        cat "$SK_FAKE_RECOVERY_NAMES"
        ;;
    %guixpc-home-package-specifications)
        cat "$SK_FAKE_HOME_NAMES"
        ;;
    *)
        printf 'unexpected fake Guile request: %s\n' "${4:-missing}" >&2
        exit 75
        ;;
esac
EOF
chmod +x "$fake_guile"

cat >"$fake_guix" <<'EOF'
#!/bin/sh
set -eu

printf 'CALL' >>"$SK_FAKE_GUIX_LOG"
for arg in "$@"; do
    printf '\t%s' "$arg" >>"$SK_FAKE_GUIX_LOG"
done
printf '\n' >>"$SK_FAKE_GUIX_LOG"

while [ "${1:-}" = -L ]; do
    shift 2
done

if [ "${1:-}" = time-machine ]; then
    [ "${SK_FAKE_FAIL:-}" != channels ] || exit 71
    [ "${HOME:?}" != "${SK_FAKE_ORIGINAL_HOME:?}" ] || exit 78
    [ -d "${XDG_CACHE_HOME:?}" ] || exit 79
    [ -r "${XDG_CONFIG_HOME:?}/guix/trusted-channels.scm" ] || exit 76
    cmp -s "$SK_FAKE_CHANNELS" \
        "$XDG_CONFIG_HOME/guix/trusted-channels.scm" || exit 77
    printf '%s\n' "$SK_FAKE_GUIX_PROFILE"
    exit 0
fi

case ${1:-} in
    describe)
        if [ "${SK_FAKE_FAIL:-}" = provenance ]; then
            guix_commit=dddddddddddddddddddddddddddddddddddddddd
        else
            guix_commit=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
        fi
        cat <<EOF_DESCRIBE
name: guix
commit: $guix_commit

name: nonguix
commit: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb

name: sk-guix
commit: cccccccccccccccccccccccccccccccccccccccc
EOF_DESCRIBE
        ;;
    show)
        if [ "${SK_FAKE_FAIL:-}" = exwm ]; then
            version=0.36
        else
            version=0.35
        fi
        printf 'name: emacs-exwm\nversion: %s\n' "$version"
        ;;
    build)
        case $* in
            *kitty-latest*) stage=promoted ;;
            *fish-latest*) stage=fish ;;
            *core-lisp.scm*) stage=core-manifest ;;
            *jvm-lisp.scm*) stage=jvm-manifest ;;
            *racket.scm*) stage=racket-manifest ;;
            *) stage=unknown-build ;;
        esac
        [ "${SK_FAKE_FAIL:-}" != "$stage" ] || exit 72
        printf '/gnu/store/fake-%s\n' "$stage"
        ;;
    home)
        [ "${SK_FAKE_FAIL:-}" != home ] || exit 73
        printf '%s\n' "${SK_FAKE_HOME:?}"
        ;;
    system)
        [ "${SK_FAKE_FAIL:-}" != system ] || exit 74
        printf '%s\n' "${SK_FAKE_SYSTEM:?}"
        ;;
    shell)
        case $* in
            *core-lisp.scm*clojure*|*core-lisp.scm*racket*|\
            *jvm-lisp.scm*guile*|*jvm-lisp.scm*sbcl*|*jvm-lisp.scm*racket*|\
            *racket.scm*guile*|*racket.scm*sbcl*|*racket.scm*clojure*)
                exit "${SK_FAKE_ABSENT_STATUS:-127}"
                ;;
            *core-lisp.scm*) stage=core-runtime ;;
            *jvm-lisp.scm*) stage=jvm-runtime ;;
            *racket.scm*) stage=racket-runtime ;;
            *) stage=unknown-runtime ;;
        esac
        [ "${SK_FAKE_FAIL:-}" != "$stage" ] || exit 72
        ;;
    package)
        profile=
        while [ "$#" -gt 0 ]; do
            case $1 in
                -p)
                    profile=$2
                    shift 2
                    ;;
                *) shift ;;
            esac
        done
        case $profile in
            "$SK_FAKE_SYSTEM/profile") cat "$SK_FAKE_SYSTEM_MANIFEST" ;;
            "$SK_FAKE_HOME/profile") cat "$SK_FAKE_HOME_MANIFEST" ;;
            *)
                printf 'unexpected fake profile: %s\n' "$profile" >&2
                exit 75
                ;;
        esac
        ;;
    *)
        printf 'unexpected fake Guix command: %s\n' "$*" >&2
        exit 75
        ;;
esac
EOF
chmod +x "$fake_guix"
ln -s "$fake_guix" "$fake_profile/bin/guix"

run_gate() {
    : >"$fake_log"
    PATH=$sandbox_home/bin:$PATH \
        HOME=$sandbox_home \
        SK_FAKE_GUIX_LOG=$fake_log \
        SK_FAKE_GUIX_PROFILE=$fake_profile \
        SK_FAKE_SYSTEM=$fake_system \
        SK_FAKE_HOME=$fake_home \
        SK_FAKE_SYSTEM_MANIFEST=$fake_system_manifest \
        SK_FAKE_HOME_MANIFEST=$fake_home_manifest \
        SK_FAKE_RECOVERY_NAMES=$fake_recovery_names \
        SK_FAKE_HOME_NAMES=$fake_home_names \
        SK_FAKE_CHANNELS=$sandbox_repo/guix/channels.scm \
        SK_FAKE_ORIGINAL_HOME=$sandbox_home \
        SK_FAKE_FAIL=${SK_FAKE_FAIL:-} \
        SK_FAKE_ABSENT_STATUS=${SK_FAKE_ABSENT_STATUS:-127} \
        SK_FAKE_FISH_STATUS=${SK_FAKE_FISH_STATUS:-0} \
        "$gate" "$@"
}

logged_command() {
    tab=$(printf '\t')
    awk -F "$tab" -v command="$1" '
        $2 == command { found = 1 }
        END { exit !found }
    ' "$fake_log"
}

logged_argument() {
    tab=$(printf '\t')
    awk -F "$tab" -v argument="$1" '
        {
            for (field = 2; field <= NF; field += 1) {
                if ($field == argument) found = 1
            }
        }
        END { exit !found }
    ' "$fake_log"
}

output=$(run_gate)
contains "$output" 'guix-build-gate: PASS (mode=build)'
log=$(cat "$fake_log")
contains "$log" 'time-machine'
contains "$log" '-q'
contains "$log" '--allow-untrusted-channels=no'
contains "$log" '--max-jobs=1'
contains "$log" '--cores=4'
contains "$log" 'show'
contains "$log" 'emacs-exwm'
contains "$log" 'kitty-latest'
contains "$log" 'go-github-com-emmansun-base64'
contains "$log" 'go-github-com-sgtdi-fswatcher'
contains "$log" 'fish-latest'
contains "$log" "$sandbox_repo/guix/manifests/core-lisp.scm"
contains "$log" "$sandbox_repo/guix/manifests/jvm-lisp.scm"
contains "$log" "$sandbox_repo/guix/manifests/racket.scm"
contains "$log" 'guile'
contains "$log" 'sbcl'
contains "$log" 'clojure'
contains "$log" 'raco'
contains "$log" "$sandbox_repo/guix/home/guixpc.scm"
contains "$log" "$sandbox_repo/guix/systems/guixpc.scm"
contains "$output" 'System recovery profile: PASS'
contains "$output" 'Realized package ownership: PASS (overlap=emacs,fish,guile)'
contains "$output" 'Non-login SSH Fish environment: PASS'

if output=$(SK_FAKE_FISH_STATUS=96 run_gate 2>&1); then
    fail 'non-login Fish validation failure passed the gate'
fi
contains "$output" 'non-login SSH Fish lacks Home-first environment'

if output=$(SK_FAKE_ABSENT_STATUS=70 run_gate 2>&1); then
    fail 'non-127 absence failure passed the leakage gate'
fi
contains "$output" 'absence probe'
contains "$output" 'inconclusive (status 70)'

rm "$fake_system/profile/bin/fish"
if output=$(run_gate 2>&1); then
    fail 'System profile missing Fish passed the gate'
fi
contains "$output" 'System recovery profile lacks fish'
write_fake_fish

rm "$fake_home/profile/bin/btop"
if output=$(run_gate 2>&1); then
    fail 'Home profile missing btop passed the gate'
fi
contains "$output" 'Home profile lacks btop'
printf '%s\n' '#!/bin/sh' 'exit 0' >"$fake_home/profile/bin/btop"
chmod +x "$fake_home/profile/bin/btop"

rm "$fake_home/profile/share/fish/functions/fenv.fish"
rm "$fake_home/profile/share/fish/functions/fenv.main.fish"
if output=$(run_gate 2>&1); then
    fail 'Home profile missing Fish foreign-env passed the gate'
fi
contains "$output" 'Home profile lacks Fish foreign-env support'
printf '%s\n' 'function fenv' 'end' \
    >"$fake_home/profile/share/fish/functions/fenv.fish"
printf '%s\n' 'function fenv.main' 'end' \
    >"$fake_home/profile/share/fish/functions/fenv.main.fish"

remove_fake_manifest_package "$fake_home_manifest" shellcheck
if output=$(run_gate 2>&1); then
    fail 'Home manifest missing declared ShellCheck passed the gate'
fi
contains "$output" 'Home profile lacks declared package: shellcheck'
write_fake_manifest "$fake_home_manifest" \
    emacs emacs-desktop-environment emacs-geiser emacs-sly fish \
    fish-foreign-env guile lua-language-server python-lsp-server ranger sbcl \
    shellcheck ungoogled-chromium

printf '%s\t1\tout\t/gnu/store/fake-guile\n' guile \
    >>"$fake_system_manifest"
if output=$(run_gate 2>&1); then
    fail 'duplicate System manifest name passed the gate'
fi
contains "$output" 'duplicate System profile package: guile'
write_fake_manifest "$fake_system_manifest" \
    bluez curl emacs emacs-exwm fish git guile kitty-latest ncurses picom \
    ripgrep vim xrandr xset xwallpaper

replace_fake_manifest_path "$fake_home_manifest" fish \
    /gnu/store/different-fish
if output=$(run_gate 2>&1); then
    fail 'different Fish store paths passed the overlap gate'
fi
contains "$output" 'overlap package differs between profiles: fish'
write_fake_manifest "$fake_home_manifest" \
    emacs emacs-desktop-environment emacs-geiser emacs-sly fish \
    fish-foreign-env guile lua-language-server python-lsp-server ranger sbcl \
    shellcheck ungoogled-chromium

printf '%s\t1\tout\t/gnu/store/fake-sbcl\n' sbcl \
    >>"$fake_system_manifest"
if output=$(run_gate 2>&1); then
    fail 'System manifest containing Home-owned SBCL passed the gate'
fi
contains "$output" 'realized System/Home package overlap changed'
write_fake_manifest "$fake_system_manifest" \
    bluez curl emacs emacs-exwm fish git guile kitty-latest ncurses picom \
    ripgrep vim xrandr xset xwallpaper

printf '%s\t1\tout\t/gnu/store/fake-racket\n' racket \
    >>"$fake_home_manifest"
if output=$(run_gate 2>&1); then
    fail 'optional Racket package in Home passed the gate'
fi
contains "$output" 'optional dialect leaked into Home: racket'
write_fake_manifest "$fake_home_manifest" \
    emacs emacs-desktop-environment emacs-geiser emacs-sly fish \
    fish-foreign-env guile lua-language-server python-lsp-server ranger sbcl \
    shellcheck ungoogled-chromium

printf '%s\t1\tout\t/gnu/store/fake-racket\n' racket \
    >>"$fake_system_manifest"
if output=$(run_gate 2>&1); then
    fail 'optional Racket package in System passed the gate'
fi
contains "$output" 'optional dialect leaked into System: racket'
write_fake_manifest "$fake_system_manifest" \
    bluez curl emacs emacs-exwm fish git guile kitty-latest ncurses picom \
    ripgrep vim xrandr xset xwallpaper

for forbidden in pull reconfigure switch-generation delete-generations gc; do
    if logged_argument "$forbidden"; then
        fail "gate invoked forbidden command: $forbidden"
    fi
done

output=$(run_gate --plan)
contains "$output" 'guix-build-gate: PASS (mode=plan)'
plan_log=$(cat "$fake_log")
dry_run_count=$(printf '%s\n' "$plan_log" | awk '
    {
        for (field = 1; field <= NF; field += 1) {
            if ($field == "--dry-run") count += 1
        }
    }
    END { print count + 0 }
')
[ "$dry_run_count" -eq 7 ] || \
    fail "plan used --dry-run $dry_run_count times; expected 7"

for stage in channels provenance exwm promoted fish core-manifest jvm-manifest \
    racket-manifest core-runtime jvm-runtime racket-runtime home system; do
    if output=$(SK_FAKE_FAIL=$stage run_gate 2>&1); then
        fail "$stage failure passed the gate"
    fi
    case $stage in
        channels|provenance|exwm|promoted|fish|core-manifest|jvm-manifest|racket-manifest|core-runtime|jvm-runtime|racket-runtime)
            if logged_command home; then
                fail "$stage failure continued into Home"
            fi
            ;;
        home)
            if logged_command system; then
                fail 'Home failure continued into System'
            fi
            ;;
        system) ;;
    esac
done

write_channels moving
if output=$(run_gate 2>&1); then
    fail 'malformed channel commit passed the gate'
fi
contains "$output" 'must pin guix, nonguix, and sk-guix'
if [ -s "$fake_log" ]; then
    fail 'invalid channel pins invoked Guix'
fi

write_channels
awk '
    BEGIN { skipped = 0 }
    /^[[:space:]]*\(introduction/ && !skipped { skipped = 1; next }
    { print }
' "$sandbox_repo/guix/channels.scm" >"$tmp/missing-introduction.scm"
cp "$tmp/missing-introduction.scm" "$sandbox_repo/guix/channels.scm"
if output=$(run_gate 2>&1); then
    fail 'missing channel introduction passed the gate'
fi
contains "$output" 'every pinned channel must carry an introduction'
if [ -s "$fake_log" ]; then
    fail 'missing channel introduction invoked Guix'
fi

if output=$(run_gate unexpected 2>&1); then
    fail 'unexpected argument passed the gate'
fi
contains "$output" 'usage:'

printf '%s\n' 'guix-build-gate-check: PASS'
