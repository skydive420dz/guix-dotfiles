#!/bin/sh
set -eu

source_repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)
sandbox=$(mktemp -d "${TMPDIR:-/tmp}/guix-reconfigure-check.XXXXXX")
trap 'rm -rf -- "$sandbox"' EXIT HUP INT TERM

repo=$sandbox/repo
home=$sandbox/home
fake_guix=$sandbox/store/guix-command
fake_guile=$sandbox/store/guile
fake_log=$sandbox/reconfigure.log
wrapper=$repo/scripts/guix-reconfigure

mkdir -p "$repo/scripts" "$repo/guix/home" "$repo/guix/modules" \
    "$home/.config/guix/current/bin" "$(dirname "$fake_guix")"
cp "$source_repo/scripts/guix-reconfigure" "$wrapper"
chmod +x "$wrapper"
cp "$source_repo/scripts/guix-home-links-preflight.scm" \
    "$repo/scripts/guix-home-links-preflight.scm"
cp "$source_repo/guix/home/repo-links.scm" \
    "$repo/guix/home/repo-links.scm"
cp "$source_repo/guix/home/repo-links-manifest.scm" \
    "$repo/guix/home/repo-links-manifest.scm"

printf '%s\n' '#!/bin/sh' 'exit 0' >"$repo/scripts/guix-entrypoints"
chmod +x "$repo/scripts/guix-entrypoints"
printf '%s\n' '(home-environment)' >"$repo/guix/home/guixpc.scm"

for source in \
    shell/bash_profile shell/bashrc shell/zprofile shell/xinitrc \
    emacs/exwm-loader.el emacs/init.el emacs/exwm.el gdb/gdbinit \
    guile/guile x11/Xdefaults kitty/kitty.conf ranger/rc.conf \
    ranger/rifle.conf ranger/scope.sh; do
    mkdir -p "$repo/$(dirname "$source")"
    printf 'fixture: %s\n' "$source" >"$repo/$source"
done

cat >"$repo/guix/channels.scm" <<'EOF'
(list
 (channel
  (name 'guix)
  (url "https://example.org/guix.git")
  (branch "master")
  (commit "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
  (introduction
   (make-channel-introduction
    "1111111111111111111111111111111111111111"
    (openpgp-fingerprint "AAAA BBBB"))))
 (channel
  (name 'nonguix)
  (url "https://example.org/nonguix.git")
  (branch "master")
  (commit "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb")
  (introduction
   (make-channel-introduction
    "2222222222222222222222222222222222222222"
    (openpgp-fingerprint "CCCC DDDD"))))
 (channel
  (name 'sk-guix)
  (url "https://example.org/sk-guix.git")
  (branch "main")
  (commit "cccccccccccccccccccccccccccccccccccccccc")
  (introduction
   (make-channel-introduction
    "3333333333333333333333333333333333333333"
    (openpgp-fingerprint "EEEE FFFF")))))
EOF

cat >"$fake_guix" <<'EOF'
#!/bin/sh
set -eu

if [ "${1:-}" = describe ]; then
    printf '%s\n' DESCRIBE >>"${SK_FAKE_LOG:?}"
    guix_url=https://example.org/guix.git
    guix_branch=master
    guix_commit=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
    guix_intro=1111111111111111111111111111111111111111
    guix_signer='AAAA BBBB'
    case ${SK_FAKE_MISMATCH:-} in
        url) guix_url=https://mirror.example.org/guix.git ;;
        branch) guix_branch=testing ;;
        commit) guix_commit=dddddddddddddddddddddddddddddddddddddddd ;;
        introduction) guix_intro=4444444444444444444444444444444444444444 ;;
        signer) guix_signer='9999 9999' ;;
    esac
    cat <<EOF_RECORDS
name: guix
url: $guix_url
branch: $guix_branch
commit: $guix_commit
introductioncommit: $guix_intro
introductionsigner: $guix_signer

name: nonguix
url: https://example.org/nonguix.git
branch: master
commit: bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
introductioncommit: 2222222222222222222222222222222222222222
introductionsigner: CCCC DDDD

name: sk-guix
url: https://example.org/sk-guix.git
branch: main
commit: cccccccccccccccccccccccccccccccccccccccc
introductioncommit: 3333333333333333333333333333333333333333
introductionsigner: EEEE FFFF
EOF_RECORDS
    if [ "${SK_FAKE_MISMATCH:-}" = extra ]; then
        cat <<'EOF_EXTRA'

name: extra
url: https://example.org/extra.git
branch: main
commit: eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee
EOF_EXTRA
    fi
    exit 0
fi

printf 'CALL' >>"${SK_FAKE_LOG:?}"
for argument in "$@"; do
    printf '\t%s' "$argument" >>"$SK_FAKE_LOG"
done
printf '\n' >>"$SK_FAKE_LOG"
EOF
chmod +x "$fake_guix"

cat >"$fake_guile" <<'EOF'
#!/bin/sh
set -eu
printf '%s\n' PREFLIGHT >>"${SK_FAKE_LOG:?}"
[ "${SK_FAKE_HOME_PREFLIGHT_FAIL:-0}" -eq 0 ] || exit 69
EOF
chmod +x "$fake_guile"

ln -s "$fake_guix" "$home/.config/guix/current/bin/guix"
ln -s "$repo/guix/channels.scm" "$home/.config/guix/channels.scm"
ln -s "$repo/guix/home/guixpc.scm" "$home/.config/guix/home.scm"
home_config_resolved=$(readlink -f "$repo/guix/home/guixpc.scm")
module_dir_resolved=$(CDPATH='' cd "$repo/guix/modules" && pwd -P)

run_wrapper() {
    HOME=$home \
        SK_GUIX_RECONFIGURE_GUILE=${SK_TEST_GUILE:-$fake_guile} \
        SK_GUIX_FRONTEND_PROFILE=${SK_TEST_FRONTEND_PROFILE:-} \
        SK_FAKE_LOG=$fake_log \
        SK_FAKE_MISMATCH=${SK_FAKE_MISMATCH:-} \
        SK_FAKE_HOME_PREFLIGHT_FAIL=${SK_FAKE_HOME_PREFLIGHT_FAIL:-0} \
        "$wrapper" home "$@"
}

output=$(run_wrapper --print)
printf '%s\n' "$output" | grep -q 'guix-reconfigure: mode=home'
printf '%s\n' "$output" | grep -q 'guix-revision=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa'

frozen_profile=$sandbox/frozen-profile
mkdir -p "$frozen_profile/bin"
ln -s "$fake_guix" "$frozen_profile/bin/guix"
output=$(SK_TEST_FRONTEND_PROFILE=$frozen_profile run_wrapper --print)
frozen_profile_resolved=$(readlink -f "$frozen_profile")
printf '%s\n' "$output" |
    grep -q "guix-resolved=$frozen_profile_resolved/bin/guix"
if output=$(SK_TEST_FRONTEND_PROFILE=relative-profile run_wrapper --print 2>&1); then
    printf '%s\n' \
        'guix-reconfigure-check: relative frontend profile override passed' >&2
    exit 1
fi
printf '%s\n' "$output" | grep -q 'frontend profile must be absolute'

for mismatch in url branch commit introduction signer extra; do
    if output=$(SK_FAKE_MISMATCH=$mismatch run_wrapper --print 2>&1); then
        printf 'guix-reconfigure-check: %s mismatch passed\n' "$mismatch" >&2
        exit 1
    fi
    printf '%s\n' "$output" | grep -q 'current Guix channels differ'
done

: >"$fake_log"
if output=$(SK_FAKE_HOME_PREFLIGHT_FAIL=1 run_wrapper 2>&1); then
    printf '%s\n' 'guix-reconfigure-check: Home link failure passed' >&2
    exit 1
fi
grep -q '^PREFLIGHT$' "$fake_log"
if grep -q '^CALL' "$fake_log"; then
    printf '%s\n' 'guix-reconfigure-check: failed preflight invoked reconfigure' >&2
    exit 1
fi

if command -v guile >/dev/null 2>&1; then
    real_guile=$(command -v guile)
    mkdir -p "$home/.emacs.d"
    printf '%s\n' 'preserve integration blocker' >"$home/.emacs.d/init.el"
    : >"$fake_log"
    if output=$(SK_TEST_GUILE=$real_guile run_wrapper --print 2>&1); then
        printf '%s\n' \
            'guix-reconfigure-check: real Home blocker passed preflight' >&2
        exit 1
    fi
    printf '%s\n' "$output" | grep -q 'BLOCKED'
    if grep -Eq '^(DESCRIBE|CALL)' "$fake_log"; then
        printf '%s\n' \
            'guix-reconfigure-check: real blocked preflight invoked Guix' >&2
        exit 1
    fi
    rm "$home/.emacs.d/init.el"
    SK_TEST_GUILE=$real_guile run_wrapper --print >/dev/null
fi

: >"$fake_log"
run_wrapper >/dev/null
grep -q "CALL.*home.*-L.*$module_dir_resolved.*reconfigure.*$home_config_resolved" \
    "$fake_log"

printf '%s\n' 'guix-reconfigure-check: PASS'
