    fail "bounded realization evidence directory already exists"
fi
mkdir "$evidence"
cp "$work/pre/live.tsv" "$evidence/pre-live.tsv"
cp "$work/pre/store-names.txt" "$evidence/pre-store-names.txt"
cp "$work/pre/packet.txt" "$evidence/pre-packet.txt"
