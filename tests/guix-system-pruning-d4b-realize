lower_status=RUNNING
set +e
run_pinned_guix build \
    --derivations \
    --no-substitutes \
    --no-grafts \
    --no-offload \
    --max-jobs=1 \
    --cores=1 \
    --system=x86_64-linux \
    -L "$frozen_module_dir" \
    -f "$frozen_build_expression" \
    >"$work/lower.stdout" 2>"$work/lower.stderr"
lower_status=$?
set -e
cp "$work/lower.stdout" "$evidence/lower.stdout"
cp "$work/lower.stderr" "$evidence/lower.stderr"
[ "$lower_status" -eq 0 ] || {
    cat "$work/lower.stdout" >&2
    cat "$work/lower.stderr" >&2
