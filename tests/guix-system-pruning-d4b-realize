}
[ ! -s "$work/derivation-plan.stderr" ] || {
    cat "$work/derivation-plan.stderr" >&2
    fail "derivation build-plan reader emitted diagnostics"
}
[ -s "$work/derivation-plan.stdout" ] ||
    fail "derivation build-plan reader returned no paths"
LC_ALL=C sort -u "$work/derivation-plan.stdout" \
    >"$work/derivation-plan.sorted"
cmp -s "$work/derivation-plan.stdout" "$work/derivation-plan.sorted" ||
    fail "derivation build-plan paths are not unique and sorted"
grep -F -x "$derivation" "$work/derivation-plan.stdout" >/dev/null ||
    fail "derivation build plan omits the accepted derivation"
grep -F -x "$output" "$work/derivation-plan.stdout" >/dev/null ||
    fail "derivation build plan omits the accepted output"
plan_valid=1

