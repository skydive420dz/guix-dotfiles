    fail "independent terminal store inventory failed"
}
[ ! -s "$work/post-store-independent-find.stderr" ] || {
    cat "$work/post-store-independent-find.stderr" >&2
    fail "independent terminal store inventory emitted diagnostics"
}
independent_sort_status=RUNNING
set +e
LC_ALL=C sort "$work/post-store-independent.unsorted" \
    >"$work/post-store-independent.txt" \
    2>"$work/post-store-independent-sort.stderr"
independent_sort_status=$?
set -e
cp "$work/post-store-independent.txt" \
    "$evidence/post-store-independent.txt"
cp "$work/post-store-independent-sort.stderr" \
    "$evidence/post-store-independent-sort.stderr"
[ "$independent_sort_status" -eq 0 ] || {
    cat "$work/post-store-independent-sort.stderr" >&2
    fail "independent terminal store inventory sort failed"
}
[ ! -s "$work/post-store-independent-sort.stderr" ] || {
    cat "$work/post-store-independent-sort.stderr" >&2
    fail "independent terminal store inventory sort emitted diagnostics"
}
cmp -s "$evidence/post-live.tsv" \
    "$evidence/post-live-independent.tsv" ||
    fail "preflight and independent terminal live snapshots differ"
cmp -s "$evidence/post-store-names.txt" \
    "$evidence/post-store-independent.txt" ||
    fail "preflight and independent terminal store inventories differ"
postflight_completed=1
cmp -s "$evidence/pre-live.tsv" "$evidence/post-live.tsv" ||
    fail "selected live transaction surfaces changed during realization"
comm -13 \
    "$evidence/pre-store-names.txt" \
    "$evidence/post-store-names.txt" \
    >"$evidence/store-additions.txt"
comm -23 \
    "$evidence/pre-store-names.txt" \
    "$evidence/post-store-names.txt" \
    >"$evidence/store-removals.txt"
[ ! -s "$evidence/store-removals.txt" ] ||
    fail "top-level store names disappeared during realization"
additions=$(wc -l <"$evidence/store-additions.txt" | tr -d ' ')
grep -F -x "$(basename "$derivation")" \
    "$evidence/post-store-names.txt" >/dev/null ||
    fail "lowered derivation is absent from the post-store inventory"
grep -F -x "$(basename "$output")" \
    "$evidence/post-store-names.txt" >/dev/null ||
    fail "realized output is absent from the post-store inventory"

unrelated=0
: >"$evidence/store-addition-classification.tsv"
while IFS= read -r name; do
    [ -n "$name" ] || continue
    path=/gnu/store/$name
    if grep -F -x "$path" \
        "$evidence/derivation-plan.stdout" >/dev/null; then
        classification=DERIVATION-PLAN
    else
        classification=UNRELATED
        unrelated=$((unrelated + 1))
    fi
    printf '%s\t%s\n' "$classification" "$path" \
        >>"$evidence/store-addition-classification.tsv"
done <"$evidence/store-additions.txt"
[ "$unrelated" -eq 0 ] ||
    fail "top-level store additions escape the accepted derivation build plan"

snapshot_manifest "$frozen_repo" "$work/source-post"
cp "$work/source-post.metadata" "$evidence/source-post.metadata"
cp "$work/source-post.sha256" "$evidence/source-post.sha256"
cmp -s "$work/source-pre.metadata" "$work/source-post.metadata" ||
    fail "accepted checkpoint export metadata changed during realization"
cmp -s "$work/source-pre.sha256" "$work/source-post.sha256" ||
    fail "accepted checkpoint export bytes changed during realization"

if ! terminal_git_status=$(run_clean_git -C "$repo" status --porcelain); then
    fail "cannot inspect the terminal checkout state"
fi
[ -z "$terminal_git_status" ] ||
    fail "accepted checkout changed during realization"
terminal_top=$(run_clean_git -C "$repo" rev-parse --show-toplevel)
terminal_git_dir=$(run_clean_git -C "$repo" rev-parse --absolute-git-dir)
terminal_head=$(run_clean_git -C "$repo" rev-parse HEAD)
terminal_origin=$(run_clean_git -C "$repo" rev-parse origin/main)
[ "$terminal_top" = "$repo" ] ||
    fail "terminal Git proof resolved another work tree"
if [ "$terminal_git_dir" != "$repo/.git" ] ||
    [ ! -d "$terminal_git_dir" ] ||
    [ -L "$terminal_git_dir" ]; then
    fail "terminal Git proof resolved another Git directory"
fi
[ "$terminal_head" = "$head" ] ||
    fail "accepted checkout HEAD changed during realization"
[ "$terminal_origin" = "$head" ] ||
    fail "origin/main changed during realization"

cat "$work/lower.stderr" >&2
cat "$work/build.stderr" >&2
printf '%s\n' \
    "schema=p5.2b-d4b-first-realization/v1" \
    "authorization=EXACT-COMMIT-BOUND-TOKEN" \
    "checkpoint=$head" \
    "render=$expected_render_sha:$expected_render_size" \
    "preflight-snapshot=$snapshot" \
    "derivation=$derivation" \
    "output=$output" \
    "state=$realization_state" \
    "lower-status=$lower_status" \
    "output-reader-status=$reader_status" \
    "derivation-plan-status=$plan_status" \
    "build-status=$build_status" \
    "postflight-status=$postflight_status" \
    "independent-live-status=$independent_live_status" \
    "independent-store-status=$independent_store_status" \
    "independent-store-sort-status=$independent_sort_status" \
    "store-additions=$additions" \
    "store-additions-unrelated=0" \
    "store-removals=0" \
    "selected-live-surfaces=IDENTICAL" \
    "result-link=ABSENT" \
    "evidence=$evidence" \
    "live-action=NOT-GRANTED" \
    "$program_name: PASS" \
    >"$work/realization-result.tsv"
cp "$work/realization-result.tsv" "$evidence/realization-result.tsv"
cat "$work/realization-result.tsv"
