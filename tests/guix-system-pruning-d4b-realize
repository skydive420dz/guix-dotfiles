chmod -R a-w "$frozen_repo"

snapshot_manifest() {
    manifest_root=$1
    manifest_prefix=$2
    find "$manifest_root" -printf '%P\t%y\t%m\t%l\n' \
        >"$manifest_prefix.metadata.unsorted"
    LC_ALL=C sort "$manifest_prefix.metadata.unsorted" \
        >"$manifest_prefix.metadata"
    find "$manifest_root" -type f -print \
        >"$manifest_prefix.files.unsorted"
    LC_ALL=C sort "$manifest_prefix.files.unsorted" \
        >"$manifest_prefix.files"
    : >"$manifest_prefix.sha256"
    while IFS= read -r file; do
        relative=${file#"$manifest_root"/}
        file_sha=$(sha256_file "$file")
        printf '%s\t%s\n' "$file_sha" "$relative" \
            >>"$manifest_prefix.sha256"
    done <"$manifest_prefix.files"
}

snapshot_manifest "$frozen_repo" "$work/source-pre"
source_archive_sha=$(sha256_file "$work/source.tar")
source_archive_size=$(stat -c '%s' "$work/source.tar")
source_file_count=$(wc -l <"$work/source-pre.files" | tr -d ' ')
source_metadata_sha=$(sha256_file "$work/source-pre.metadata")
source_files_sha=$(sha256_file "$work/source-pre.sha256")
printf '%s\n' \
    "schema=p5.2b-d4b-source-snapshot/v1" \
    "checkpoint=$head" \
    "archive=$source_archive_sha:$source_archive_size" \
    "regular-files=$source_file_count" \
    "metadata-sha256=$source_metadata_sha" \
    "file-identities-sha256=$source_files_sha" \
    >"$work/source-snapshot.tsv"

set +e
"$preflight" --capture "$work/pre" \
    >"$work/preflight.stdout" 2>"$work/preflight.stderr"
preflight_status=$?
set -e
[ "$preflight_status" -eq 0 ] || {
    cat "$work/preflight.stderr" >&2
    cat "$work/preflight.stdout" >&2
    fail "fresh bounded preflight failed"
}
[ ! -s "$work/preflight.stderr" ] || {
    cat "$work/preflight.stderr" >&2
    fail "fresh bounded preflight emitted diagnostics"
}
expected_token=$(awk -F = '$1 == "acceptance-token" {
        sub(/^acceptance-token=/, "")
