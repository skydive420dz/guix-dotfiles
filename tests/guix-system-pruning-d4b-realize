cp "$work/preflight.stderr" "$evidence/preflight.stderr"
cp "$work/source-archive.stderr" "$evidence/source-archive.stderr"
cp "$work/source-extract.stdout" "$evidence/source-extract.stdout"
cp "$work/source-extract.stderr" "$evidence/source-extract.stderr"
cp "$work/source-snapshot.tsv" "$evidence/source-snapshot.tsv"
cp "$work/source-pre.metadata" "$evidence/source-pre.metadata"
cp "$work/source-pre.sha256" "$evidence/source-pre.sha256"

run_pinned_guix() {
    env -i \
        HOME="$work/home" \
        USER="$expected_user" \
        LOGNAME="$expected_user" \
