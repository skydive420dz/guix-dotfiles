if [ ! -f "$derivation" ] || [ -L "$derivation" ]; then
    fail "lowering did not return one direct derivation file"
fi
[ "$(readlink -f "$derivation")" = "$derivation" ] ||
    fail "lowered derivation path is not canonical"
[ "$(dirname "$derivation")" = /gnu/store ] ||
    fail "lowered derivation is outside /gnu/store"
case $derivation in
    *.drv) ;;
    *) fail "lowered path is not a derivation" ;;
esac

set +e
reader_status=RUNNING
run_pinned_guix repl -q -- \
    "$frozen_output_reader" "$derivation" \
    >"$work/output-reader.stdout" 2>"$work/output-reader.stderr"
reader_status=$?
set -e
cp "$work/output-reader.stdout" "$evidence/output-reader.stdout"
cp "$work/output-reader.stderr" "$evidence/output-reader.stderr"
[ "$reader_status" -eq 0 ] || {
    cat "$work/output-reader.stdout" >&2
    cat "$work/output-reader.stderr" >&2
    fail "cannot read the one lowered output"
}
[ ! -s "$work/output-reader.stderr" ] || {
    cat "$work/output-reader.stderr" >&2
    fail "derivation output reader emitted diagnostics"
}
[ "$(wc -l <"$work/output-reader.stdout" | tr -d ' ')" -eq 1 ] ||
    fail "lowered derivation did not report exactly one output"
output=$(sed -n '1p' "$work/output-reader.stdout")
[ "$(dirname "$output")" = /gnu/store ] ||
    fail "lowered output is outside /gnu/store"
case $output in
    *-system-pruning-loaded.scm) ;;
    *) fail "lowered output has the wrong artifact name" ;;
esac

set +e
plan_status=RUNNING
run_pinned_guix repl -q -- \
    "$frozen_plan_reader" "$derivation" \
    >"$work/derivation-plan.stdout" 2>"$work/derivation-plan.stderr"
plan_status=$?
set -e
cp "$work/derivation-plan.stdout" "$evidence/derivation-plan.stdout"
cp "$work/derivation-plan.stderr" "$evidence/derivation-plan.stderr"
[ "$plan_status" -eq 0 ] || {
    cat "$work/derivation-plan.stdout" >&2
    cat "$work/derivation-plan.stderr" >&2
