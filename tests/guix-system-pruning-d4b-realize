PATH=\
/gnu/store/z84fzavdzq9ja3lyln3cf9px4h45ybf9-profile/bin:/gnu/store/2p4vnz9y2ndfsbary431rzlf41jhanrs-profile/bin
export LC_ALL PATH

program_name=guix-system-pruning-d4b-realize
expected_host=guixpc
expected_user=skydive420dz
expected_uid=1000
expected_repo=/home/skydive420dz/Projects/guix-dotfiles
expected_d4a=41e11155f817c8ccf2f8e8b3c9c62af566f53209
expected_guix=\
/gnu/store/0hzhxis25c15rag5412rhm2md38chi6x-guix-command
expected_render_sha=\
95b84e29853a2327bffab857383cf78a30ab41b965144fd298edc384335b9d70
expected_render_size=956987

fail() {
    printf '%s: FAIL: %s\n' "$program_name" "$*" >&2
    exit 1
}

sha256_file() {
    if ! sha_line=$(sha256sum "$1"); then
        fail "cannot hash file: $1"
    fi
    sha_digest=${sha_line%% *}
    [ "${#sha_digest}" -eq 64 ] ||
        fail "SHA256 command returned an invalid digest: $1"
    case $sha_digest in
        *[!0-9a-f]*) fail "SHA256 command returned non-hex output: $1" ;;
    esac
    printf '%s\n' "$sha_digest"
}

run_clean_git() {
    env -i \
        HOME=/homeless-shelter \
        XDG_CONFIG_HOME=/homeless-shelter \
        USER="$expected_user" \
        LOGNAME="$expected_user" \
        PATH="$PATH" \
        LC_ALL=C \
        GIT_CONFIG_NOSYSTEM=1 \
        GIT_OPTIONAL_LOCKS=0 \
        git \
        -c core.fsmonitor=false \
        -c core.untrackedCache=false \
        "$@"
}

usage() {
    printf 'usage: %s EXACT-COMMIT-BOUND-ACCEPTANCE-TOKEN\n' \
        "$program_name" >&2
    exit 64
}

case $# in
    1) acceptance_token=$1 ;;
    *) usage ;;
esac

[ "$(hostname)" = "$expected_host" ] ||
    fail "host differs from the accepted GuixPC"
[ "$(id -un)" = "$expected_user" ] ||
    fail "user differs from the accepted unprivileged owner"
[ "$(id -u)" -eq "$expected_uid" ] ||
    fail "UID differs from the accepted unprivileged owner"

repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)
[ "$repo" = "$expected_repo" ] ||
    fail "realization gate is outside the accepted checkout"
script=$(readlink -f "$0" 2>/dev/null || true)
[ "$script" = "$repo/tests/$program_name" ] ||
    fail "realization gate path is not canonical"
if [ ! -f "$script" ] || [ -L "$script" ]; then
    fail "realization gate is not one repository-owned regular file"
fi

module_dir=$repo/guix/modules
build_expression=\
$repo/guix/machines/guixpc/p5.2b-d4b-fused-program.scm
output_reader=\
$repo/guix/machines/guixpc/p5.2b-d4b-derivation-output.scm
plan_reader=\
$repo/guix/machines/guixpc/p5.2b-d4b-derivation-plan.scm
preflight=$repo/tests/guix-system-pruning-d4b-preflight
live_snapshot=$repo/tests/guix-system-pruning-d4b-live-snapshot
for source in \
    "$build_expression" \
    "$output_reader" \
    "$plan_reader" \
    "$preflight" \
    "$live_snapshot"; do
    if [ ! -f "$source" ] || [ -L "$source" ]; then
        fail "realization input is not one repository-owned regular file: $source"
    fi
done
[ -x "$preflight" ] ||
    fail "preflight helper is not executable"
[ -x "$live_snapshot" ] ||
    fail "selected-live helper is not executable"
if [ ! -d "$module_dir" ] || [ -L "$module_dir" ]; then
    fail "project module load path is not one direct directory"
fi
if [ -n "$(find "$module_dir" -name '*.go' -print -quit)" ]; then
    fail "project module load path contains a compiled Guile object"
fi
if [ ! -x "$expected_guix" ] || [ -L "$expected_guix" ]; then
    fail "pinned Guix command is unavailable"
fi

if ! git_status=$(run_clean_git -C "$repo" status --porcelain); then
    fail "cannot inspect the accepted checkout state"
fi
[ -z "$git_status" ] ||
    fail "accepted checkout is not clean"
top=$(run_clean_git -C "$repo" rev-parse --show-toplevel)
git_dir=$(run_clean_git -C "$repo" rev-parse --absolute-git-dir)
[ "$top" = "$repo" ] ||
    fail "clean Git proof resolved another work tree"
if [ "$git_dir" != "$repo/.git" ] ||
    [ ! -d "$git_dir" ] ||
    [ -L "$git_dir" ]; then
    fail "clean Git proof resolved another Git directory"
fi
head=$(run_clean_git -C "$repo" rev-parse HEAD)
origin=$(run_clean_git -C "$repo" rev-parse origin/main)
[ "$head" = "$origin" ] ||
    fail "checkout HEAD differs from origin/main"
run_clean_git -C "$repo" merge-base --is-ancestor "$expected_d4a" "$head" ||
    fail "published D4a is not an ancestor of the accepted checkpoint"

work=$(mktemp -d /tmp/p52b-d4b-realize.XXXXXX)
evidence=
mutation_started=0
postflight_completed=0
plan_valid=0
lower_status=NOT-RUN
reader_status=NOT-RUN
plan_status=NOT-RUN
build_status=NOT-RUN
postflight_status=NOT-RUN
independent_live_status=NOT-RUN
independent_store_status=NOT-RUN
independent_sort_status=NOT-RUN

cleanup() {
    status=$?
    trap - 0 HUP INT TERM
    set +e
    if [ "$status" -ne 0 ] &&
        [ "$mutation_started" -eq 1 ] &&
        [ -n "$evidence" ] &&
        [ -d "$evidence" ]; then
        failure_capture_mode=DIRECT
        failure_live_status=UNKNOWN
        failure_store_status=UNKNOWN
        failure_sort_status=UNKNOWN
        failure_additions=UNKNOWN
        failure_removals=UNKNOWN
        failure_plan=UNAVAILABLE
        failure_plan_paths=0
        failure_unrelated=0
        failure_unclassified=0

        if [ "$postflight_completed" -eq 1 ] &&
            [ -f "$evidence/post-live.tsv" ] &&
            [ -f "$evidence/post-store-names.txt" ]; then
            failure_capture_mode=NORMAL-POSTFLIGHT
            failure_live_status=0
            failure_store_status=0
            failure_sort_status=0
            failure_live=$evidence/post-live.tsv
            failure_store=$evidence/post-store-names.txt
        else
            failure_live=$evidence/failure-post-live.tsv
            failure_store=$evidence/failure-post-store-names.txt
            "$frozen_live_snapshot" \
                >"$failure_live" \
                2>"$evidence/failure-post-live.stderr"
            failure_live_status=$?
            find /gnu/store -mindepth 1 -maxdepth 1 -printf '%f\n' \
                >"$evidence/failure-post-store-names.unsorted" \
                2>"$evidence/failure-post-store-names.stderr"
            failure_store_status=$?
            if [ "$failure_store_status" -eq 0 ]; then
                LC_ALL=C sort \
                    "$evidence/failure-post-store-names.unsorted" \
                    >"$failure_store" \
                    2>"$evidence/failure-post-store-sort.stderr"
                failure_sort_status=$?
            fi
        fi

        if [ "$failure_store_status" -eq 0 ] &&
            [ "$failure_sort_status" -eq 0 ] &&
            [ -f "$failure_store" ]; then
            comm -13 \
                "$evidence/pre-store-names.txt" \
                "$failure_store" \
                >"$evidence/failure-store-additions.txt"
            failure_additions_status=$?
            comm -23 \
                "$evidence/pre-store-names.txt" \
                "$failure_store" \
                >"$evidence/failure-store-removals.txt"
            failure_removals_status=$?
            if [ "$failure_additions_status" -eq 0 ] &&
                [ "$failure_removals_status" -eq 0 ]; then
                failure_additions=$(
                    wc -l <"$evidence/failure-store-additions.txt" |
                        tr -d ' '
                )
                failure_removals=$(
                    wc -l <"$evidence/failure-store-removals.txt" |
                        tr -d ' '
                )
                : >"$evidence/failure-store-addition-classification.tsv"
                if [ "$plan_valid" -eq 1 ] &&
                    [ -f "$evidence/derivation-plan.stdout" ]; then
                    failure_plan=VALID
                fi
                while IFS= read -r name; do
                    [ -n "$name" ] || continue
                    path=/gnu/store/$name
                    if [ "$failure_plan" = VALID ]; then
                        if grep -F -x "$path" \
                            "$evidence/derivation-plan.stdout" \
                            >/dev/null; then
                            classification=DERIVATION-PLAN
                            failure_plan_paths=$((failure_plan_paths + 1))
                        else
                            classification=UNRELATED
                            failure_unrelated=$((failure_unrelated + 1))
                        fi
                    else
                        classification=UNCLASSIFIED
                        failure_unclassified=$((failure_unclassified + 1))
                    fi
                    printf '%s\t%s\n' "$classification" "$path" \
                        >>"$evidence/failure-store-addition-classification.tsv"
                done <"$evidence/failure-store-additions.txt"
            fi
        fi

        printf '%s\n' \
            "schema=p5.2b-d4b-failure-evidence/v1" \
            "checkpoint=$head" \
            "original-exit-status=$status" \
            "lower-status=$lower_status" \
            "output-reader-status=$reader_status" \
            "derivation-plan-status=$plan_status" \
            "build-status=$build_status" \
            "postflight-status=$postflight_status" \
            "independent-live-status=$independent_live_status" \
            "independent-store-status=$independent_store_status" \
            "independent-store-sort-status=$independent_sort_status" \
            "capture-mode=$failure_capture_mode" \
            "post-live-status=$failure_live_status" \
            "post-store-status=$failure_store_status" \
            "post-store-sort-status=$failure_sort_status" \
            "store-additions=$failure_additions" \
            "store-removals=$failure_removals" \
            "derivation-plan=$failure_plan" \
            "store-additions-derivation-plan=$failure_plan_paths" \
            "store-additions-unrelated=$failure_unrelated" \
            "store-additions-unclassified=$failure_unclassified" \
            >"$evidence/failure-result.tsv"
    fi
    if [ -d "$work/source" ]; then
        chmod -R u+w "$work/source"
    fi
    rm -rf -- "$work"
    exit "$status"
}
