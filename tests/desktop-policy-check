#!/bin/sh
set -eu

repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)
system_config=$repo/guix/systems/guixpc.scm

bluetooth_service_count=$(grep -Fxc \
    "        (service bluetooth-service-type" "$system_config" || true)
bluetooth_config_count=$(grep -Fxc \
    "                 (bluetooth-configuration" "$system_config" || true)
bluetooth_auto_count=$(grep -Fxc \
    "                  (auto-enable? #t)))" "$system_config" || true)
if [ "$bluetooth_service_count:$bluetooth_config_count:$bluetooth_auto_count" != \
    1:1:1 ]; then
    printf 'desktop-policy-check: Bluetooth auto-enable policy counts are %s:%s:%s; expected 1:1:1\n' \
        "$bluetooth_service_count" "$bluetooth_config_count" \
        "$bluetooth_auto_count" >&2
    exit 1
fi

kitty_policy=$(awk '
    $1 == "allow_remote_control" {
        count += 1
        if ($2 == "no") disabled += 1
    }
    END { print count + 0 ":" disabled + 0 }
' "$repo/kitty/kitty.conf")
[ "$kitty_policy" = 1:1 ] || {
    printf 'desktop-policy-check: Kitty remote-control policy is %s; expected 1:1\n' \
        "$kitty_policy" >&2
    exit 1
}

if awk '$1 == "listen_on" || $1 == "remote_control_password" ||
        $1 == "include" || $1 == "globinclude" ||
        $1 == "envinclude" || $1 == "geninclude" { found = 1 }
        END { exit !found }' "$repo/kitty/kitty.conf"; then
    printf '%s\n' \
        'desktop-policy-check: Kitty exposes or imports remote-control policy' >&2
    exit 1
fi

if awk '
    !/^[[:space:]]*#/ &&
    $0 ~ /(^|[[:space:]])([^[:space:]]*\/)?xhost([[:space:]]|$)/ {
        found = 1
    }
    END { exit !found }
' "$repo/shell/xinitrc"; then
    printf '%s\n' 'desktop-policy-check: Xinit still expands access with xhost' >&2
    exit 1
fi

picom_count=$(grep -Fxc \
    "    if picom --config \"\$picom_config\" \\" \
    "$repo/shell/xinitrc" || true)
picom_detect_count=$(grep -Fxc \
    "        --detect-client-opacity \\" \
    "$repo/shell/xinitrc" || true)
picom_rule_count=$(grep -Fxc \
    "        --opacity-rule \"\$picom_opacity_rule\" \\" \
    "$repo/shell/xinitrc" || true)
picom_daemon_count=$(grep -Fxc \
    '        --daemon; then' \
    "$repo/shell/xinitrc" || true)
picom_condition_count=$(grep -Fxc \
    "    picom_opacity_condition='class_g = \"Emacs\" && !_NET_WM_WINDOW_OPACITY && !_NET_WM_WINDOW_OPACITY@'" \
    "$repo/shell/xinitrc" || true)
picom_gate_count=$(grep -Fxc \
    '        export SK_EMACS_STARTUP_OPACITY_PERCENT' \
    "$repo/shell/xinitrc" || true)
immutable_adapter_count=$(grep -Fxc \
    '        /gnu/store/*)' "$repo/shell/xinitrc" || true)
if [ "$picom_count:$picom_detect_count:$picom_rule_count:$picom_daemon_count:$picom_condition_count:$picom_gate_count:$immutable_adapter_count" != \
    1:1:1:1:1:1:1 ]; then
    printf 'desktop-policy-check: Xinit Picom/gate/adapter counts are %s:%s:%s:%s:%s:%s:%s; expected 1:1:1:1:1:1:1\n' \
        "$picom_count" "$picom_detect_count" "$picom_rule_count" \
        "$picom_daemon_count" "$picom_condition_count" \
        "$picom_gate_count" "$immutable_adapter_count" >&2
    exit 1
fi

session_cmdline_count=$(grep -Fc \
    "\"/proc/\$picom_pid/cmdline\"" \
    "$repo/scripts/desktop-session-check" || true)
session_exact_arguments_count=$(grep -Fc \
    "expected_picom_arguments=\$(printf" \
    "$repo/scripts/desktop-session-check" || true)
session_argv0_case_count=$(grep -Fxc \
    '        picom|*/picom)' \
    "$repo/scripts/desktop-session-check" || true)
session_legacy_ps_count=$(grep -Fc \
    "ps -u \"\$uid\" -o stat=,comm=,args=" \
    "$repo/scripts/desktop-session-check" || true)
if [ "$session_cmdline_count:$session_exact_arguments_count:$session_argv0_case_count:$session_legacy_ps_count" != \
    2:1:1:0 ]; then
    printf 'desktop-policy-check: runtime Picom argv proof counts are %s:%s:%s:%s; expected 2:1:1:0\n' \
        "$session_cmdline_count" "$session_exact_arguments_count" \
        "$session_argv0_case_count" "$session_legacy_ps_count" >&2
    exit 1
fi

printf '%s\n' 'desktop-policy-check: PASS'
