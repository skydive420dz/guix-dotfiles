    "$realization_result_size" ] ||
    fail "source realization result size changed during the matrix"
cmp -s "$realization_result_source" "$realization_result" ||
    fail "source and private realization results differ after the matrix"
[ "$(sha256_file "$realization_result")" = \
    "$realization_result_sha" ] ||
    fail "private realization result changed during the matrix"

assert_store_program "$store_program"
[ "$(sha256_file "$store_program")" = "$program_sha" ] ||
    fail "STORE_PROGRAM bytes changed during the matrix"
[ "$(stat -c '%s' "$store_program")" -eq "$program_size" ] ||
    fail "STORE_PROGRAM size changed during the matrix"

printf '%s\n' \
    "schema=p5.2b-d4b-runtime-evidence/v1" \
    "authorization=NOT-GRANTED" \
    "checkpoint=$expected_checkpoint" \
    "realization-result=$realization_result_source" \
    "realization-result-sha256=$realization_result_sha" \
    "realization-result-size=$realization_result_size" \
    "realization-state=$realization_state" \
    "derivation=$derivation" \
    "program=$store_program" \
    "program-sha256=$program_sha" \
    "program-size=$program_size" \
    "preflight-snapshot=$preflight_snapshot" \
    "store-additions=$store_additions" \
    "source-archive=$source_archive_sha:$source_archive_size" \
    "source-regular-files=$source_file_count" \
    "source-metadata-sha256=$source_metadata_sha" \
    "source-file-identities-sha256=$source_files_sha" \
    "production-suites=6" \
    "renderer-suite=SOURCE-GATE" \
    "d4a-actions=5" \
    "loader-modes=4" \
    "artifact-forward=$forward_count" \
    "artifact-rollback=$rollback_count" \
    "artifact-total=$((forward_count + rollback_count))" \
    "original-wrapper-regression=NOT-RUN" \
    "mode=FIXTURE-ONLY" \
    "live-action=NOT-GRANTED" \
    "$program_name: PASS"
