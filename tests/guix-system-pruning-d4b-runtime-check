        >"$output.metadata.unsorted"
    LC_ALL=C sort "$output.metadata.unsorted" >"$output.metadata"
    find "$root" -xdev -type f -print >"$output.file-list.unsorted"
    LC_ALL=C sort "$output.file-list.unsorted" >"$output.file-list"
    : >"$output.files"
    while IFS= read -r file; do
        file_sha=$(sha256_file "$file")
        printf '%s\t%s\n' \
            "${file#"$root"/}" \
            "$file_sha" >>"$output.files"
    done <"$output.file-list"
}

