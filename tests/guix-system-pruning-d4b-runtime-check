        }
        $1 == "retain" || $1 == "delete" {
            print $5
            next
        }
        $1 == "recovery-root" {
            print $3
        }
    ' "$manifest" | LC_ALL=C sort -u |
        while IFS= read -r logical; do
            [ -n "$logical" ] || continue
            physical=$root$logical
            mkdir -p "$(dirname "$physical")"
            case $logical in
                *-grub.cfg) : >"$physical" ;;
                *) mkdir -p "$physical" ;;
            esac
        done

    cp "$old_grub" \
        "$root/gnu/store/bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb-grub.cfg"
    cp "$new_grub" \
        "$root/gnu/store/nnnnnnnnnnnnnnnnnnnnnnnnnnnnnnnn-grub.cfg"
    cp "$old_grub" "$root/boot/grub/grub.cfg"
    chmod 0644 "$root/boot/grub/grub.cfg"
    cp "$pins" "$root/repo/generation-pins.tsv"
    cp "$efi" "$root/boot/efi/fixture-sentinel.txt"

    awk -F "$tab" '
        $1 == "retain" || $1 == "delete" {
            print $3 "\t" $4
        }
    ' "$manifest" |
        while IFS="$tab" read -r logical raw; do
            mkdir -p "$(dirname "$root$logical")"
            ln -s "$raw" "$root$logical"
        done

    awk -F "$tab" '
        $1 == "protected-symlink" {
            print $2 "\t" $3
        }
    ' "$manifest" |
        while IFS="$tab" read -r logical raw; do
            mkdir -p "$(dirname "$root$logical")"
            ln -s "$raw" "$root$logical"
        done

    ln -s "$old_bootcfg_raw" "$root/var/guix/gcroots/bootcfg"
    mkdir -p "$root$transaction_base" "$root$recovery_base"
    chmod 0700 \
        "$root/var/guix/profiles" \
        "$root$transaction_base"
}

snapshot_fixture() {
