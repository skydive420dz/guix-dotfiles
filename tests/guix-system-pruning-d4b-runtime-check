sha256_file() {
    if command -v sha256sum >/dev/null 2>&1; then
        if ! sha_line=$(sha256sum "$1"); then
            fail "cannot hash file: $1"
        fi
    elif command -v shasum >/dev/null 2>&1; then
        if ! sha_line=$(shasum -a 256 "$1"); then
            fail "cannot hash file: $1"
        fi
    else
        fail "no SHA256 command is available"
    fi
    sha_digest=${sha_line%% *}
    [ "${#sha_digest}" -eq 64 ] ||
        fail "SHA256 command returned an invalid digest: $1"
    case $sha_digest in
        *[!0-9a-f]*) fail "SHA256 command returned non-hex output: $1" ;;
    esac
    printf '%s\n' "$sha_digest"
}

assert_store_program() {
    candidate=$1
    case $candidate in
        /*) ;;
        *) fail "STORE_PROGRAM is not absolute: $candidate" ;;
    esac
    [ -f "$candidate" ] || fail "STORE_PROGRAM is not a regular file"
    [ ! -L "$candidate" ] || fail "STORE_PROGRAM must not be a symlink"
    [ -x "$candidate" ] || fail "STORE_PROGRAM is not executable"

    canonical=$(readlink -f "$candidate" 2>/dev/null || true)
    [ "$canonical" = "$candidate" ] ||
        fail "STORE_PROGRAM is not its canonical path"
    [ "$(dirname "$candidate")" = /gnu/store ] ||
        fail "STORE_PROGRAM is outside /gnu/store"

    name=$(basename "$candidate")
    [ "${#name}" -eq $((32 + ${#store_suffix})) ] ||
        fail "STORE_PROGRAM store name has the wrong length"
    hash=${name%"$store_suffix"}
    [ "${#hash}" -eq 32 ] ||
        fail "STORE_PROGRAM store hash has the wrong length"
    [ "$name" = "$hash$store_suffix" ] ||
        fail "STORE_PROGRAM suffix differs from $store_suffix"
    invalid=$(printf '%s' "$hash" | tr -d "$store_alphabet")
    [ -z "$invalid" ] || fail "STORE_PROGRAM store hash is invalid"

    [ "$(stat -c '%u' "$candidate")" -eq 0 ] ||
        fail "STORE_PROGRAM is not owned by root"
    mode=$(stat -c '%a' "$candidate")
    user_mode=$((mode / 100))
    group_mode=$(((mode / 10) % 10))
    other_mode=$((mode % 10))
    for digit in "$user_mode" "$group_mode" "$other_mode"; do
        case $digit in
            0 | 1 | 4 | 5) ;;
            *) fail "STORE_PROGRAM is writable: mode=$mode" ;;
        esac
    done
}

