snapshot_manifest() {
    manifest_root=$1
    manifest_prefix=$2
    find "$manifest_root" -printf '%P\t%y\t%m\t%l\n' \
        >"$manifest_prefix.metadata.unsorted"
    LC_ALL=C sort "$manifest_prefix.metadata.unsorted" \
        >"$manifest_prefix.metadata"
    find "$manifest_root" -type f -print \
        >"$manifest_prefix.files.unsorted"
    LC_ALL=C sort "$manifest_prefix.files.unsorted" \
        >"$manifest_prefix.files"
    : >"$manifest_prefix.sha256"
    while IFS= read -r file; do
        relative=${file#"$manifest_root"/}
        file_sha=$(sha256_file "$file")
        printf '%s\t%s\n' "$file_sha" "$relative" \
            >>"$manifest_prefix.sha256"
    done <"$manifest_prefix.files"
}

