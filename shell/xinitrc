#!/bin/sh
# shellcheck disable=SC1090,SC1091
set -e

if [ -r /etc/profile ]; then
    . /etc/profile
fi

if [ -r "$HOME/.profile" ]; then
    . "$HOME/.profile"
fi

export XDG_CURRENT_DESKTOP=EXWM
export XDG_SESSION_DESKTOP=exwm
export XDG_SESSION_TYPE=x11
export DESKTOP_SESSION=exwm

sk_theme_active=0
theme_adapter="${XDG_CONFIG_HOME:-$HOME/.config}/sk-theme/x-session.sh"
if [ -r "$theme_adapter" ]; then
    theme_adapter_resolved=$(readlink -f "$theme_adapter" 2>/dev/null || true)
    case $theme_adapter_resolved in
        /gnu/store/*)
            . "$theme_adapter"
            sk_theme_active=1
            ;;
        *)
            printf 'EXWM: ignoring mutable theme adapter: %s\n' \
                "$theme_adapter" >&2
            ;;
    esac
fi

if [ -z "${XDG_RUNTIME_DIR:-}" ]; then
    printf '%s\n' 'EXWM: Guix Home did not set XDG_RUNTIME_DIR' >&2
    exit 1
fi

session_bus_socket="$XDG_RUNTIME_DIR/bus"
expected_session_bus="unix:path=$session_bus_socket"
if [ "${DBUS_SESSION_BUS_ADDRESS:-}" != "$expected_session_bus" ]; then
    printf 'EXWM: expected Home D-Bus at %s, got %s\n' \
        "$expected_session_bus" "${DBUS_SESSION_BUS_ADDRESS:-<unset>}" >&2
    exit 1
fi

tries=0
while [ ! -S "$session_bus_socket" ] && [ "$tries" -lt 50 ]; do
    sleep 0.1
    tries=$((tries + 1))
done
if [ ! -S "$session_bus_socket" ]; then
    printf 'EXWM: Home D-Bus socket is unavailable: %s\n' \
        "$session_bus_socket" >&2
    exit 1
fi

if ! command -v dbus-update-activation-environment >/dev/null 2>&1; then
    printf '%s\n' 'EXWM: dbus-update-activation-environment is unavailable' >&2
    exit 1
fi

dbus-update-activation-environment \
    DBUS_SESSION_BUS_ADDRESS \
    DISPLAY XAUTHORITY \
    XDG_RUNTIME_DIR XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE \
    DESKTOP_SESSION

# This desktop never auto-suspends, but X blanks and powers down the monitor
# after ten minutes of X input inactivity.  This is display protection, not a
# screen lock; tty1 autologin is accepted for this trusted physical single-user
# workstation.
if command -v xset >/dev/null 2>&1; then
    xset s blank || printf '%s\n' 'EXWM: failed to enable X blanking' >&2
    xset s 600 600 || printf '%s\n' 'EXWM: failed to set X blanking timeout' >&2
    xset +dpms || printf '%s\n' 'EXWM: failed to enable DPMS' >&2
    xset dpms 600 600 600 || \
        printf '%s\n' 'EXWM: failed to set DPMS timeouts' >&2
fi

if command -v xrandr >/dev/null 2>&1; then
    if ! xrandr --query | grep -q '^   3440x1440.*100\.00\*'; then
        xrandr --output HDMI-A-0 --mode 3440x1440 --rate 100 || true
    fi
fi

if [ "$sk_theme_active" -eq 1 ]; then
    wallpaper_file="${XDG_DATA_HOME:-$HOME/.local/share}/sk-theme/$SK_THEME_WALLPAPER"
    wallpaper_fit=$SK_THEME_WALLPAPER_FIT
else
    wallpaper_file="$HOME/Projects/guix-dotfiles/assets/wallpapers/waifu-cyberpunk.png"
    wallpaper_fit=zoom
fi

if command -v xwallpaper >/dev/null 2>&1 && [ -r "$wallpaper_file" ]; then
    case $wallpaper_fit in
        zoom) xwallpaper --zoom "$wallpaper_file" || true ;;
        *)
            printf 'EXWM: unsupported wallpaper fit: %s\n' \
                "$wallpaper_fit" >&2
            ;;
    esac
fi

unset SK_EMACS_STARTUP_OPACITY_PERCENT
if command -v picom >/dev/null 2>&1; then
    pkill -x picom 2>/dev/null || true
    if [ "$sk_theme_active" -eq 1 ]; then
        if [ "$SK_THEME_PICOM_CONFIG:$SK_THEME_PICOM_BACKEND:$SK_THEME_PICOM_VSYNC" != \
            /dev/null:glx:true ]; then
            printf '%s\n' \
                'EXWM: generated Picom policy contains an unsupported value' >&2
            exit 1
        fi
        picom_config=$SK_THEME_PICOM_CONFIG
        picom_backend=$SK_THEME_PICOM_BACKEND
        picom_emacs_opacity_percent=$SK_THEME_PICOM_EMACS_OPACITY_PERCENT
    else
        picom_config=/dev/null
        picom_backend=glx
        picom_emacs_opacity_percent=85
    fi

    case $picom_emacs_opacity_percent in
        ''|*[!0-9]*)
            printf 'EXWM: invalid Picom opacity: %s\n' \
                "$picom_emacs_opacity_percent" >&2
            exit 1
            ;;
    esac
    if [ "$picom_emacs_opacity_percent" -lt 1 ] || \
       [ "$picom_emacs_opacity_percent" -gt 100 ]; then
        printf 'EXWM: Picom opacity is outside 1..100: %s\n' \
            "$picom_emacs_opacity_percent" >&2
        exit 1
    fi

    picom_opacity_condition='class_g = "Emacs" && !_NET_WM_WINDOW_OPACITY && !_NET_WM_WINDOW_OPACITY@'
    picom_opacity_rule="$picom_emacs_opacity_percent:$picom_opacity_condition"
    if picom --config "$picom_config" \
        --backend "$picom_backend" --vsync \
        --detect-client-opacity \
        --opacity-rule "$picom_opacity_rule" \
        --daemon; then
        # Export only after the compositor owns the display.  Emacs consumes
        # and clears this one-shot token after EXWM's final workspace geometry.
        SK_EMACS_STARTUP_OPACITY_PERCENT=$picom_emacs_opacity_percent
        export SK_EMACS_STARTUP_OPACITY_PERCENT
    else
        printf '%s\n' \
            'EXWM: Picom failed; continuing without the startup opacity gate' \
            >&2
    fi
fi

exec emacs -fs --eval '(load-file "~/.exwm")'
