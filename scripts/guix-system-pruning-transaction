#!/bin/sh
set -eu

program='guix-system-pruning-transaction'
repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)
module_dir=$repo/guix/modules
driver=$repo/scripts/guix-system-pruning-transaction.scm
frontend=${SK_GUIX_FRONTEND_PROFILE:-${HOME:?}/.config/guix/current}

usage() {
    printf 'usage: %s fixture-points|fixture-verify|fixture-apply|fixture-recover MANIFEST FIXTURE-ROOT\n' \
        "$program" >&2
    exit 64
}

fail() {
    printf '%s: FAIL: %s\n' "$program" "$*" >&2
    exit 1
}

sha256_file() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{ print $1 }'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{ print $1 }'
    else
        fail "no SHA256 command is available"
    fi
}

[ "$#" -eq 3 ] || usage
action=$1
manifest=$2
root=$3

case $action in
    fixture-points | fixture-verify | fixture-apply | fixture-recover) ;;
    *) usage ;;
esac

case $manifest in
    /*) ;;
    *) fail "fixture manifest must be absolute: $manifest" ;;
esac
case $root in
    /*) ;;
    *) fail "fixture root must be absolute: $root" ;;
esac

[ "$(id -u)" -ne 0 ] || fail "fixture transaction refuses uid 0"
if [ ! -f "$manifest" ] || [ -L "$manifest" ]; then
    fail "fixture manifest is not a regular file"
fi
if [ ! -d "$root" ] || [ -L "$root" ]; then
    fail "fixture root is not a real directory"
fi

root=$(CDPATH='' cd "$root" && pwd -P) ||
    fail "cannot canonicalize fixture root"
[ "$root" != / ] || fail "live root is forbidden"
if [ ! -f "$root/.p52b-system-transaction-fixture" ] ||
    [ -L "$root/.p52b-system-transaction-fixture" ]; then
    fail "fixture sentinel is missing"
fi
[ "$(sed -n '1p' "$root/.p52b-system-transaction-fixture")" = \
    p5.2b-system-transaction-fixture/v1 ] ||
    fail "fixture sentinel is invalid"

manifest_sha=${SK_P52B_D3_MANIFEST_SHA:-}
[ -n "$manifest_sha" ] ||
    fail "SK_P52B_D3_MANIFEST_SHA must bind the fixture manifest"
[ "$(sha256_file "$manifest")" = "$manifest_sha" ] ||
    fail "fixture manifest SHA256 mismatch"

check_repository_input() {
    label=$1
    relative=$2
    expected=$3
    case $relative in
        /* | ../* | */../* | */.. | ./* | */./* | */.)
            fail "unsafe repository input path: $relative"
            ;;
    esac
    if [ ! -f "$repo/$relative" ] || [ -L "$repo/$relative" ]; then
        fail "$label is not a repository-owned regular file"
    fi
    actual=$(sha256_file "$repo/$relative")
    [ "$actual" = "$expected" ] ||
        fail "$label SHA256 differs from the fixture manifest"
}

tab=$(printf '\t')
while IFS="$tab" read -r key label relative expected extra; do
    [ "$key" = implementation-input ] || continue
    if [ -z "$label" ] || [ -z "$relative" ] || [ -z "$expected" ] ||
        [ -n "${extra:-}" ]; then
        fail "invalid implementation-input record"
    fi
    check_repository_input "$label" "$relative" "$expected"
done <"$manifest"

registry=$(
    awk -F "$tab" '
        $1 == "crash-registry" && NF == 3 {
            count++
            print $2 "\t" $3
        }
        END { if (count != 1) exit 1 }
    ' "$manifest"
) || fail "invalid crash-registry record"
IFS="$tab" read -r registry_path registry_sha <<EOF
$registry
EOF
check_repository_input crash-registry "$registry_path" "$registry_sha"

frontend_resolved=$(readlink -f "$frontend") ||
    fail "cannot resolve Guix frontend profile: $frontend"
guix=$frontend_resolved/bin/guix
[ -x "$guix" ] || fail "pinned Guix is unavailable: $guix"

expected_revision=$(
    awk -F "$tab" '
        $1 == "guix-revision" && NF == 2 {
            count++
            print $2
        }
        END { if (count != 1) exit 1 }
    ' "$manifest"
) || fail "invalid guix-revision record"
actual_revision=$(
    "$guix" describe --format=recutils |
        awk '
            $1 == "name:" { name = $2 }
            name == "guix" && $1 == "commit:" {
                revision = $2
            }
            END {
                if (revision == "") exit 1
                print revision
            }
        '
) || fail "cannot identify the running Guix revision"
[ "$actual_revision" = "$expected_revision" ] ||
    fail "running Guix revision differs from the fixture manifest"

exec env -u GUILE_LOAD_PATH \
    -u GUILE_LOAD_COMPILED_PATH \
    -u GUILE_EXTENSIONS_PATH \
    GUILE_AUTO_COMPILE=0 \
    SK_GUIX_REVISION="$actual_revision" \
    "$guix" repl -L "$module_dir" -q -- \
    "$driver" "$action" "$manifest" "$root" "$repo"
