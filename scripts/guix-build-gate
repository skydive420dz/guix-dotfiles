#!/bin/sh

set -eu

usage() {
    printf 'usage: %s [--plan]\n' "$0" >&2
    exit 64
}

case $# in
    0) plan=0 ;;
    1)
        [ "$1" = --plan ] || usage
        plan=1
        ;;
    *) usage ;;
esac

home=${HOME:?HOME must be set}
script_dir=$(CDPATH='' cd "$(dirname "$0")" && pwd -P)
repo=$(CDPATH='' cd "$script_dir/.." && pwd -P)
channels=$repo/guix/channels.scm
home_config=$repo/guix/home/guixpc.scm
system_config=$repo/guix/systems/guixpc.scm
module_dir=$repo/guix/modules
manifest_dir=$repo/guix/manifests
racket_fixture=$repo/fixtures/racket/basic-test.rkt
elisp_fixture=$repo/fixtures/elisp/sk-example
guile_fixture=$repo/fixtures/guile
common_lisp_fixture=$repo/fixtures/common-lisp
emacs_check=$repo/scripts/emacs-check
emacs_clojure_check=$repo/scripts/emacs-clojure-check
lisp_project_check=$repo/scripts/lisp-project-check
clojure_project_check=$repo/scripts/clojure-project-check
guile_init=$repo/guile/guile
frontend_input=${SK_GUIX_FRONTEND_PROFILE:-$home/.config/guix/current}
substitute_urls='https://ci.guix.gnu.org https://bordeaux.guix.gnu.org https://substitutes.nonguix.org'
promoted_expression='(list (@ (sk packages terminals) kitty-latest) (@ (sk packages golang) go-github-com-emmansun-base64) (@ (sk packages golang) go-github-com-sgtdi-fswatcher))'
quarantined_expression='(@ (sk packages shells) fish-latest)'

for file in "$channels" "$home_config" "$system_config" \
    "$module_dir/sk/development-tiers.scm" \
    "$manifest_dir/core-lisp.scm" \
    "$manifest_dir/jvm-lisp.scm" \
    "$manifest_dir/racket.scm" \
    "$racket_fixture" \
    "$elisp_fixture/Makefile" \
    "$elisp_fixture/sk-example.el" \
    "$elisp_fixture/test/sk-example-test.el" \
    "$guile_fixture/Makefile" \
    "$guile_fixture/src/sk/fixture/math.scm" \
    "$guile_fixture/tests/math-test.scm" \
    "$common_lisp_fixture/Makefile" \
    "$common_lisp_fixture/sk-fixture.asd" \
    "$common_lisp_fixture/src/package.lisp" \
    "$common_lisp_fixture/src/core.lisp" \
    "$common_lisp_fixture/tests/package.lisp" \
    "$common_lisp_fixture/tests/core.lisp" \
    "$emacs_check" \
    "$emacs_clojure_check" \
    "$lisp_project_check" \
    "$clojure_project_check" \
    "$guile_init"; do
    if [ ! -r "$file" ]; then
        printf 'guix-build-gate: unreadable declaration: %s\n' "$file" >&2
        exit 2
    fi
done

for checker in "$emacs_check" "$emacs_clojure_check" "$lisp_project_check" \
    "$clojure_project_check"; do
    if [ ! -x "$checker" ]; then
        printf 'guix-build-gate: candidate checker is not executable: %s\n' \
            "$checker" >&2
        exit 2
    fi
done

case $frontend_input in
    /*) ;;
    *)
        printf 'guix-build-gate: frontend profile must be absolute: %s\n' \
            "$frontend_input" >&2
        exit 2
        ;;
esac
frontend_profile=$(readlink -f "$frontend_input") || {
    printf 'guix-build-gate: cannot resolve frontend profile: %s\n' \
        "$frontend_input" >&2
    exit 2
}
bootstrap_guix=$frontend_profile/bin/guix
if [ ! -x "$bootstrap_guix" ]; then
    printf 'guix-build-gate: frontend Guix is not executable: %s\n' \
        "$bootstrap_guix" >&2
    exit 2
fi

for command in awk cat cmp comm cp guile ln mkdir mktemp readlink rm sort; do
    if ! command -v "$command" >/dev/null 2>&1; then
        printf 'guix-build-gate: missing command: %s\n' "$command" >&2
        exit 2
    fi
done

tmp=$(mktemp -d "${TMPDIR:-/tmp}/sk-guix-build-gate.XXXXXX")
cleanup() {
    rm -rf -- "$tmp"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

expected_channels=$tmp/expected-channels
actual_channels=$tmp/actual-channels
describe_output=$tmp/describe.rec
channel_snapshot=$tmp/channels.scm
isolated_config=$tmp/config
isolated_cache=$tmp/cache
isolated_data=$tmp/data
isolated_home=$tmp/home
isolated_state=$tmp/state
runtime_work=$tmp/runtime-work
trusted_channels=$isolated_config/guix/trusted-channels.scm
cp "$channels" "$channel_snapshot"

awk '
    /\(name '\''[^)]*\)/ {
        name = $0
        sub(/^.*\(name '\''/, "", name)
        sub(/\).*/, "", name)
        next
    }
    /\(commit "[^"]*"\)/ && name != "" {
        commit = $0
        sub(/^.*\(commit "/, "", commit)
        sub(/".*/, "", commit)
        print name, commit
        name = ""
    }
' "$channel_snapshot" >"$expected_channels"

if ! awk '
    NF != 2 || length($2) != 40 || $2 ~ /[^0-9a-f]/ { bad = 1 }
    $1 == "guix" { guix += 1 }
    $1 == "nonguix" { nonguix += 1 }
    $1 == "sk-guix" { sk_guix += 1 }
    END {
        exit !(!bad && NR == 3 && guix == 1 && nonguix == 1 && sk_guix == 1)
    }
' "$expected_channels"; then
    printf '%s\n' \
        'guix-build-gate: channels.scm must pin guix, nonguix, and sk-guix to unique 40-hex commits' >&2
    exit 2
fi

introduction_count=$(awk '
    /^[[:space:]]*\(introduction([[:space:]]|$)/ { count += 1 }
    END { print count + 0 }
' "$channel_snapshot")
if [ "$introduction_count" -ne 3 ]; then
    printf '%s\n' \
        'guix-build-gate: every pinned channel must carry an introduction' >&2
    exit 2
fi

mkdir -p "$isolated_config/guix" "$isolated_cache" "$isolated_data" \
    "$isolated_home" "$isolated_state" "$runtime_work"
cp "$channel_snapshot" "$trusted_channels"

export LC_ALL=C
export TZ=UTC
export GUILE_AUTO_COMPILE=0
unset GUILE_LOAD_COMPILED_PATH GUILE_LOAD_PATH GUIX_BUILD_OPTIONS GUIX_PACKAGE_PATH

printf '%s\n' '== pinned channel profile =='
profile=$(
    HOME="$isolated_home" \
    XDG_CACHE_HOME="$isolated_cache" \
    XDG_CONFIG_HOME="$isolated_config" \
    "$bootstrap_guix" time-machine \
        -q \
        -C "$channel_snapshot" \
        --allow-untrusted-channels=no \
        --substitute-urls="$substitute_urls" \
        --max-jobs=1 \
        --cores=4
)
pinned_guix=$profile/bin/guix
if [ ! -x "$pinned_guix" ]; then
    printf 'guix-build-gate: time-machine returned no executable Guix profile: %s\n' \
        "$profile" >&2
    exit 1
fi
printf 'Pinned Guix profile: %s\n' "$profile"

"$pinned_guix" describe --format=recutils >"$describe_output"
cat "$describe_output"
awk '
    $1 == "name:" { name = $2; next }
    $1 == "commit:" && name != "" { print name, $2; name = "" }
' "$describe_output" >"$actual_channels"

if ! awk '
    NF != 2 || length($2) != 40 || $2 ~ /[^0-9a-f]/ { bad = 1 }
    END { exit !(NR == 3 && !bad) }
' "$actual_channels"; then
    printf '%s\n' 'guix-build-gate: pinned Guix returned invalid channel provenance' >&2
    exit 1
fi

sort "$expected_channels" >"$expected_channels.sorted"
sort "$actual_channels" >"$actual_channels.sorted"
if ! cmp -s "$expected_channels.sorted" "$actual_channels.sorted"; then
    printf '%s\n' 'guix-build-gate: time-machine provenance differs from channels.scm' >&2
    printf '%s\n' '-- expected --' >&2
    cat "$expected_channels.sorted" >&2
    printf '%s\n' '-- actual --' >&2
    cat "$actual_channels.sorted" >&2
    exit 1
fi

exwm_version=$(
    "$pinned_guix" show emacs-exwm |
        awk '$1 == "version:" { print $2; exit }'
)
if [ "$exwm_version" != 0.35 ]; then
    printf 'guix-build-gate: reviewed EXWM version changed: expected 0.35, got %s\n' \
        "${exwm_version:-missing}" >&2
    exit 1
fi
printf 'Reviewed EXWM version: %s\n' "$exwm_version"

run_promoted_packages() {
    if [ "$plan" -eq 1 ]; then
        "$pinned_guix" build \
            --dry-run \
            --no-grafts \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            --expression="$promoted_expression"
    else
        "$pinned_guix" build \
            --no-grafts \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            --expression="$promoted_expression"
    fi
}

run_manifest() {
    manifest=$1
    if [ "$plan" -eq 1 ]; then
        "$pinned_guix" build -L "$module_dir" \
            --dry-run \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            --manifest="$manifest"
    else
        "$pinned_guix" build -L "$module_dir" \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            --manifest="$manifest"
    fi
}

run_manifest_command() {
    manifest=$1
    shift
    (
        cd "$runtime_work"
        HOME="$isolated_home" \
            XDG_CACHE_HOME="$isolated_cache" \
            XDG_CONFIG_HOME="$isolated_config" \
            "$pinned_guix" shell -L "$module_dir" --pure \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            -m "$manifest" -- "$@"
    )
}

assert_manifest_absent() {
    manifest=$1
    command=$2
    output=$tmp/absent-$command.out
    if run_manifest_command "$manifest" "$command" --version \
        >"$output" 2>&1; then
        printf 'guix-build-gate: %s leaked into %s\n' \
            "$command" "$manifest" >&2
        exit 1
    else
        status=$?
    fi
    if [ "$status" -ne 127 ]; then
        printf 'guix-build-gate: %s absence probe in %s was inconclusive (status %s)\n' \
            "$command" "$manifest" "$status" >&2
        cat "$output" >&2
        exit 1
    fi
}

run_home() {
    if [ "$plan" -eq 1 ]; then
        "$pinned_guix" home \
            --dry-run \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            build "$home_config"
    else
        "$pinned_guix" home \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            build "$home_config"
    fi
}

run_system() {
    if [ "$plan" -eq 1 ]; then
        "$pinned_guix" system \
            --dry-run \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            build "$system_config"
    else
        "$pinned_guix" system \
            --substitute-urls="$substitute_urls" \
            --max-jobs=1 \
            --cores=4 \
            build "$system_config"
    fi
}

validate_system_recovery_profile() {
    system=$1
    profile=$system/profile
    if [ ! -d "$profile" ]; then
        printf 'guix-build-gate: System result has no profile: %s\n' \
            "$system" >&2
        exit 1
    fi

    for command in bluetoothctl curl dbus-update-activation-environment emacs \
        fish git kitty picom reset rg startx vim xrandr xset xwallpaper; do
        if [ ! -x "$profile/bin/$command" ]; then
            printf 'guix-build-gate: System recovery profile lacks %s\n' \
                "$command" >&2
            exit 1
        fi
    done

    exwm_found=0
    for path in "$profile"/share/emacs/site-lisp/exwm-*; do
        if [ -d "$path" ]; then
            exwm_found=1
            break
        fi
    done
    if [ "$exwm_found" -ne 1 ]; then
        printf '%s\n' \
            'guix-build-gate: System recovery profile lacks EXWM site-lisp' >&2
        exit 1
    fi

    for module in readline colorized; do
        module_file=$profile/share/guile/site/3.0/ice-9/$module.scm
        if [ ! -r "$module_file" ]; then
            printf 'guix-build-gate: System profile lacks Guile module: %s\n' \
                "$module" >&2
            exit 1
        fi
    done

    for command in bb clj clj-kondo cljfmt clojure clojure-lsp gradle java \
        javac lein mvn; do
        if [ -e "$profile/bin/$command" ]; then
            printf 'guix-build-gate: optional JVM command leaked into System: %s\n' \
                "$command" >&2
            exit 1
        fi
    done

    printf 'System recovery profile: PASS (%s)\n' "$profile"
}

write_declared_package_names() {
    variable=$1
    output=$2
    raw=$tmp/$variable-raw
    if ! guile -c '
        (let ((source (cadr (command-line)))
              (variable (string->symbol (caddr (command-line)))))
          (primitive-load source)
          (for-each (lambda (name) (display name) (newline))
                    (module-ref (current-module) variable)))
    ' "$repo/guix/package-ownership.scm" "$variable" >"$raw"; then
        printf 'guix-build-gate: cannot read ownership variable: %s\n' \
            "$variable" >&2
        exit 1
    fi
    sort -u "$raw" >"$output"
    if [ ! -s "$output" ]; then
        printf 'guix-build-gate: ownership variable is empty: %s\n' \
            "$variable" >&2
        exit 1
    fi
}

write_profile_package_records() {
    profile=$1
    label=$2
    output=$3
    raw=$tmp/$label-installed
    unsorted=$tmp/$label-records-unsorted

    "$pinned_guix" package -p "$profile" --list-installed >"$raw"
    if ! awk -v label="$label" '
        NF < 4 {
            printf "guix-build-gate: malformed %s profile row: %s\n", \
                label, $0 > "/dev/stderr"
            bad = 1
            next
        }
        seen[$1]++ {
            printf "guix-build-gate: duplicate %s profile package: %s\n", \
                label, $1 > "/dev/stderr"
            bad = 1
        }
        { print $1 "\t" $3 "\t" $4 }
        END { exit bad }
    ' "$raw" >"$unsorted"; then
        exit 1
    fi
    sort "$unsorted" >"$output"
    if [ ! -s "$output" ]; then
        printf 'guix-build-gate: %s profile manifest is empty\n' "$label" >&2
        exit 1
    fi
}

profile_has_package() {
    records=$1
    package=$2
    awk -F '\t' -v package="$package" '
        $1 == package { found = 1 }
        END { exit !found }
    ' "$records"
}

require_profile_packages() {
    records=$1
    label=$2
    names=$3
    while IFS= read -r package; do
        [ -n "$package" ] || continue
        if ! profile_has_package "$records" "$package"; then
            printf 'guix-build-gate: %s profile lacks declared package: %s\n' \
                "$label" "$package" >&2
            exit 1
        fi
    done <"$names"
}

validate_home_profile_artifacts() {
    home_result=$1
    profile=$home_result/profile
    if [ ! -d "$profile" ]; then
        printf 'guix-build-gate: Home result has no profile: %s\n' \
            "$home_result" >&2
        exit 1
    fi

    for command in bat btop chafa chromium clang cljfmt clj-kondo emacs \
        fastfetch fzf gcc gdb guile jq lua lua-language-server make \
        mediainfo pamixer pipemixer pylsp ranger ruff sbcl shellcheck shfmt; do
        if [ ! -x "$profile/bin/$command" ]; then
            printf 'guix-build-gate: Home profile lacks %s\n' "$command" >&2
            exit 1
        fi
    done

    for library in clojure-mode eshell-syntax-highlighting geiser geiser-guile \
        org package-lint puni sly use-package yasnippet; do
        found=0
        for path in "$profile/share/emacs/site-lisp/$library"-*; do
            if [ -e "$path" ]; then
                found=1
                break
            fi
        done
        if [ "$found" -ne 1 ]; then
            printf 'guix-build-gate: Home profile lacks %s site-lisp\n' \
                "$library" >&2
            exit 1
        fi
    done

    if [ ! -r "$profile/share/fish/functions/fenv.fish" ] || \
       [ ! -r "$profile/share/fish/functions/fenv.main.fish" ]; then
        printf '%s\n' \
            'guix-build-gate: Home profile lacks Fish foreign-env support' >&2
        exit 1
    fi

    # cljfmt and clj-kondo are deliberate Home editor tools.  The JVM,
    # language server, dependency/build clients, and Clojure launchers must
    # remain confined to the project manifest even when propagated inputs
    # would not appear as top-level profile package records.
    for command in bb clj clojure clojure-lsp gradle java javac lein mvn; do
        if [ -e "$profile/bin/$command" ]; then
            printf 'guix-build-gate: optional JVM command leaked into Home: %s\n' \
                "$command" >&2
            exit 1
        fi
    done
}

validate_nonlogin_fish_environment() {
    system_result=$1
    home_result=$2
    fish_home=$tmp/fish-home
    fish_runtime=$tmp/fish-runtime
    fish_config=$home_result/files/.config/fish/config.fish
    fish_profile=$home_result/files/.profile

    if [ ! -r "$fish_config" ] || [ ! -r "$fish_profile" ]; then
        printf '%s\n' \
            'guix-build-gate: Home result lacks generated Fish/profile files' >&2
        exit 1
    fi

    mkdir -p "$fish_home" "$fish_runtime"
    ln -s "$home_result" "$fish_home/.guix-home"
    ln -s "$fish_profile" "$fish_home/.profile"
    : >"$fish_runtime/on-first-login-executed"

    # The single-quoted command body is evaluated by Fish.
    # shellcheck disable=SC2016
    if ! HOME="$fish_home" \
        PATH="$system_result/profile/bin" \
        SSH_CONNECTION=build-gate \
        XDG_RUNTIME_DIR="$fish_runtime" \
        SK_FISH_CONFIG="$fish_config" \
        "$system_result/profile/bin/fish" --no-config --command '
            command -q shellcheck; and exit 90
            command -q sbcl; and exit 91
            source "$SK_FISH_CONFIG"
            test "$PATH[1]" = "$HOME/.guix-home/profile/bin"; or exit 92
            command -q shellcheck; or exit 93
            command -q sbcl; or exit 94
            string match -q \
                "$HOME/.guix-home/profile/share/emacs/site-lisp*" \
                "$EMACSLOADPATH"; or exit 95
        '; then
        printf '%s\n' \
            'guix-build-gate: non-login SSH Fish lacks Home-first environment' >&2
        exit 1
    fi

    printf '%s\n' 'Non-login SSH Fish environment: PASS'
}

validate_realized_package_ownership() {
    system_result=$1
    home_result=$2
    system_records=$tmp/system-package-records
    home_records=$tmp/home-package-records
    system_names=$tmp/system-package-names
    home_names=$tmp/home-package-names
    declared_recovery=$tmp/declared-recovery-names
    declared_home=$tmp/declared-home-names
    expected_overlap=$tmp/expected-profile-overlap
    actual_overlap=$tmp/actual-profile-overlap

    write_profile_package_records \
        "$system_result/profile" System "$system_records"
    write_profile_package_records "$home_result/profile" Home "$home_records"
    awk -F '\t' '{ print $1 }' "$system_records" >"$system_names"
    awk -F '\t' '{ print $1 }' "$home_records" >"$home_names"

    write_declared_package_names \
        %guixpc-recovery-package-specifications "$declared_recovery"
    write_declared_package_names \
        %guixpc-home-package-specifications "$declared_home"
    require_profile_packages "$system_records" System "$declared_recovery"
    require_profile_packages "$home_records" Home "$declared_home"
    if ! profile_has_package "$system_records" kitty-latest; then
        printf '%s\n' \
            'guix-build-gate: System profile lacks declared package: kitty-latest' >&2
        exit 1
    fi
    for package in guile-readline guile-colorized; do
        if ! profile_has_package "$system_records" "$package"; then
            printf 'guix-build-gate: System profile lacks base package: %s\n' \
                "$package" >&2
            exit 1
        fi
    done

    for package in babashka clojure clojure-tools clojure-lsp clj-kondo \
        cljfmt gradle leiningen maven openjdk racket emacs-clojure-mode \
        emacs-cider emacs-flycheck-clj-kondo emacs-racket-mode; do
        if profile_has_package "$system_records" "$package"; then
            printf 'guix-build-gate: optional dialect leaked into System: %s\n' \
                "$package" >&2
            exit 1
        fi
    done
    for package in babashka clojure clojure-tools clojure-lsp gradle \
        leiningen maven openjdk racket emacs-cider emacs-flycheck-clj-kondo \
        emacs-racket-mode; do
        if profile_has_package "$home_records" "$package"; then
            printf 'guix-build-gate: optional dialect leaked into Home: %s\n' \
                "$package" >&2
            exit 1
        fi
    done

    printf '%s\n' emacs fish guile >"$expected_overlap"
    comm -12 "$system_names" "$home_names" >"$actual_overlap"
    if ! cmp -s "$expected_overlap" "$actual_overlap"; then
        printf '%s\n' \
            'guix-build-gate: realized System/Home package overlap changed' >&2
        printf '%s\n' '-- expected --' >&2
        cat "$expected_overlap" >&2
        printf '%s\n' '-- actual --' >&2
        cat "$actual_overlap" >&2
        exit 1
    fi

    for package in emacs fish guile; do
        system_record=$(awk -F '\t' -v package="$package" \
            '$1 == package { print; exit }' "$system_records")
        home_record=$(awk -F '\t' -v package="$package" \
            '$1 == package { print; exit }' "$home_records")
        if [ "$system_record" != "$home_record" ]; then
            printf 'guix-build-gate: overlap package differs between profiles: %s\n' \
                "$package" >&2
            exit 1
        fi
    done

    printf '%s\n' \
        'Realized package ownership: PASS (overlap=emacs,fish,guile)'
}

validate_guile_profile_environment() {
    system_result=$1
    home_result=$2
    system_profile=$system_result/profile
    home_profile=$home_result/profile

    if ! output=$(
        (
            unset INSIDE_EMACS
            HOME="$isolated_home" \
                XDG_CACHE_HOME="$isolated_cache" \
                XDG_CONFIG_HOME="$isolated_config" \
                XDG_DATA_HOME="$isolated_data" \
                XDG_STATE_HOME="$isolated_state" \
                GUILE_AUTO_COMPILE=0 \
                GUILE_HISTORY="$tmp/guile-history" \
                GUILE_LOAD_PATH="$home_profile/share/guile/site/3.0:$system_profile/share/guile/site/3.0" \
                GUILE_LOAD_COMPILED_PATH="$home_profile/lib/guile/3.0/site-ccache:$home_profile/share/guile/site/3.0:$system_profile/lib/guile/3.0/site-ccache:$system_profile/share/guile/site/3.0" \
                "$home_profile/bin/guile" --no-auto-compile \
                -l "$guile_init" \
                -c '(use-modules (ice-9 readline) (ice-9 colorized))
                    (unless (and (procedure? activate-readline)
                                 (procedure? activate-colorized))
                      (error "missing Guile REPL activator"))
                    (let* ((common
                            (resolve-module
                             (quote (system repl common))))
                           (colorized
                            (resolve-module (quote (ice-9 colorized))))
                           (options
                            (module-ref
                             common (quote repl-default-options)))
                           (printer
                            (cadr (assq (quote print) options)))
                           (expected
                            (module-ref
                             colorized
                             (quote colorized-repl-printer))))
                      (unless (eq? printer expected)
                        (error ".guile did not activate colorized output")))
                    (display "candidate-guile-ready\n")'
        ) 2>&1
    ); then
        printf '%s\n' "$output" >&2
        printf '%s\n' \
            'guix-build-gate: candidate Guile startup failed' >&2
        exit 1
    fi

    case $output in
        *"Consider installing"*)
            printf '%s\n' "$output" >&2
            printf '%s\n' \
                'guix-build-gate: candidate .guile used a missing-module fallback' >&2
            exit 1
            ;;
    esac

    printf '%s\n' 'Candidate Guile profile: PASS'
}

validate_elisp_project_fixture() {
    home_result=$1
    system_result=$2
    home_profile=$home_result/profile
    system_profile=$system_result/profile

    if ! HOME="$isolated_home" \
        TMPDIR="$runtime_work" \
        PATH="$home_profile/bin:$system_profile/bin:$system_profile/sbin" \
        EMACS="$home_profile/bin/emacs" \
        EMACSLOADPATH="$home_profile/share/emacs/site-lisp:$system_profile/share/emacs/site-lisp:" \
        "$lisp_project_check" elisp "$repo"; then
        printf '%s\n' \
            'guix-build-gate: candidate Emacs Lisp fixture check failed' >&2
        exit 1
    fi

    printf '%s\n' 'Candidate Emacs Lisp fixture: PASS'
}

validate_core_lisp_project_fixtures() {
    if ! run_manifest_command "$manifest_dir/core-lisp.scm" \
        "$lisp_project_check" guile "$repo"; then
        printf '%s\n' \
            'guix-build-gate: Guile project fixture check failed' >&2
        exit 1
    fi
    printf '%s\n' 'Guile project fixture: PASS'

    if ! run_manifest_command "$manifest_dir/core-lisp.scm" \
        "$lisp_project_check" common-lisp "$repo"; then
        printf '%s\n' \
            'guix-build-gate: Common Lisp project fixture check failed' >&2
        exit 1
    fi
    printf '%s\n' 'Common Lisp project fixture: PASS'
}

assert_no_clojure_cache_escape() {
    for path in \
        "$isolated_home/.m2" \
        "$isolated_home/.clojure" \
        "$isolated_home/.babashka" \
        "$isolated_home/.gradle" \
        "$isolated_home/.lein" \
        "$repo/fixtures/clojure/.cpcache" \
        "$repo/fixtures/clojure/.lsp/.cache" \
        "$repo/fixtures/clojure/.clj-kondo/.cache" \
        "$repo/fixtures/clojure/target"; do
        if [ -e "$path" ]; then
            printf 'guix-build-gate: Clojure cache escaped isolation: %s\n' \
                "$path" >&2
            exit 1
        fi
    done
}

validate_jvm_clojure_project() {
    output=$tmp/clojure-project-check.out
    assert_no_clojure_cache_escape
    if ! run_manifest_command "$manifest_dir/jvm-lisp.scm" \
        env GUIX="$pinned_guix" "$clojure_project_check" "$repo" \
        >"$output" 2>&1; then
        cat "$output" >&2
        printf '%s\n' \
            'guix-build-gate: Clojure project fixture check failed' >&2
        exit 1
    fi
    cat "$output"
    if ! awk '$0 == "clojure-project-check: PASS" { pass = 1 }
              END { exit !pass }' "$output"; then
        printf '%s\n' \
            'guix-build-gate: Clojure project fixture omitted its PASS marker' >&2
        exit 1
    fi
    assert_no_clojure_cache_escape
    printf '%s\n' 'Clojure project fixture: PASS'
}

validate_candidate_emacs() {
    home_result=$1
    system_result=$2

    SK_EMACS_CHECK_HOME_PROFILE="$home_result/profile" \
        SK_EMACS_CHECK_SYSTEM_PROFILE="$system_result/profile" \
        SK_EMACS_CHECK_BREAK_LIVE=0 \
        SK_EMACS_CHECK_BREAK_BATCH=0 \
        SK_EMACS_CHECK_BREAK_WARNING=0 \
        SK_EMACS_CHECK_BREAK_BACKEND=0 \
        "$emacs_check" --batch-only "$repo"

    printf '%s\n' 'Candidate Emacs batch: PASS'
}

validate_candidate_emacs_clojure() {
    home_result=$1
    system_result=$2
    output=$tmp/emacs-clojure-check.out

    if ! HOME="$isolated_home" \
        TMPDIR="$runtime_work" \
        XDG_CACHE_HOME="$isolated_cache" \
        XDG_CONFIG_HOME="$isolated_config" \
        XDG_DATA_HOME="$isolated_data" \
        XDG_STATE_HOME="$isolated_state" \
        GUIX_ENVIRONMENT='' \
        GUIX="$pinned_guix" \
        SK_EMACS_CHECK_HOME_PROFILE="$home_result/profile" \
        SK_EMACS_CHECK_SYSTEM_PROFILE="$system_result/profile" \
        SK_EMACS_CLOJURE_CHECK_BREAK=0 \
        "$emacs_clojure_check" "$repo" >"$output" 2>&1; then
        cat "$output" >&2
        printf '%s\n' \
            'guix-build-gate: candidate Emacs Clojure backend check failed' >&2
        exit 1
    fi
    cat "$output"
    if ! awk '$0 == "emacs-clojure-check: PASS" { pass = 1 }
              END { exit !pass }' "$output"; then
        printf '%s\n' \
            'guix-build-gate: candidate Emacs Clojure backend omitted its PASS marker' >&2
        exit 1
    fi
    printf '%s\n' 'Candidate Emacs Clojure backend: PASS'
}

printf '%s\n' '== promoted sk-guix packages =='
run_promoted_packages

printf '%s\n' '== quarantined sk-guix package evaluation =='
"$pinned_guix" build \
    --dry-run \
    --no-grafts \
    --substitute-urls="$substitute_urls" \
    --max-jobs=1 \
    --cores=4 \
    --expression="$quarantined_expression"

for manifest in core-lisp jvm-lisp racket; do
    printf '== %s development manifest ==\n' "$manifest"
    run_manifest "$manifest_dir/$manifest.scm"
done

if [ "$plan" -eq 0 ]; then
    printf '%s\n' '== isolated development runtime probes =='
    run_manifest_command "$manifest_dir/core-lisp.scm" \
        guile -c \
        '(use-modules (ice-9 readline) (ice-9 colorized)) (display (+ 20 22)) (newline)'
    run_manifest_command "$manifest_dir/core-lisp.scm" \
        sbcl --noinform --non-interactive \
        --eval '(require :asdf)' \
        --eval '(format t "~a~%" (asdf:asdf-version))'
    validate_core_lisp_project_fixtures
    assert_manifest_absent "$manifest_dir/core-lisp.scm" clojure
    assert_manifest_absent "$manifest_dir/core-lisp.scm" racket

    run_manifest_command "$manifest_dir/jvm-lisp.scm" java -version
    run_manifest_command "$manifest_dir/jvm-lisp.scm" cljfmt --version
    run_manifest_command "$manifest_dir/jvm-lisp.scm" clj-kondo --version
    run_manifest_command "$manifest_dir/jvm-lisp.scm" clojure-lsp --version
    validate_jvm_clojure_project
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" bb
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" clojure
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" clj
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" gradle
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" lein
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" mvn
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" guile
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" sbcl
    assert_manifest_absent "$manifest_dir/jvm-lisp.scm" racket

    run_manifest_command "$manifest_dir/racket.scm" \
        racket -e '(displayln (+ 20 22))'
    run_manifest_command "$manifest_dir/racket.scm" \
        raco test "$racket_fixture"
    assert_manifest_absent "$manifest_dir/racket.scm" guile
    assert_manifest_absent "$manifest_dir/racket.scm" sbcl
    assert_manifest_absent "$manifest_dir/racket.scm" clojure
fi

printf '%s\n' '== Guix Home declaration =='
if [ "$plan" -eq 1 ]; then
    run_home
else
    home_result=$(run_home)
    printf 'guix-build-gate: home-result=%s\n' "$home_result"
    printf '%s\n' "$home_result"
    validate_home_profile_artifacts "$home_result"
fi

printf '%s\n' '== Guix System declaration =='
if [ "$plan" -eq 1 ]; then
    run_system
else
    system_result=$(run_system)
    printf 'guix-build-gate: system-result=%s\n' "$system_result"
    printf '%s\n' "$system_result"
    validate_system_recovery_profile "$system_result"
    validate_realized_package_ownership "$system_result" "$home_result"
    validate_guile_profile_environment "$system_result" "$home_result"
    validate_nonlogin_fish_environment "$system_result" "$home_result"
    validate_elisp_project_fixture "$home_result" "$system_result"
    validate_candidate_emacs "$home_result" "$system_result"
    validate_candidate_emacs_clojure "$home_result" "$system_result"
fi

if [ "$plan" -eq 1 ]; then
    mode=plan
else
    mode=build
fi
printf 'guix-build-gate: PASS (mode=%s)\n' "$mode"
