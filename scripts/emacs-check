#!/bin/sh
set -u

batch_only=0
if [ "${1:-}" = --batch-only ]; then
    batch_only=1
    shift
fi

if [ "$#" -gt 1 ]; then
    printf 'usage: %s [--batch-only] [REPOSITORY]\n' "$0" >&2
    exit 2
fi

real_home="${HOME:?HOME must be set}"
repo="${1:-$real_home/Projects/guix-dotfiles}"
repo="$(CDPATH='' cd -- "$repo" && pwd -P)" || exit 2

if [ "$batch_only" -eq 0 ] && \
   { [ "${SK_EMACS_CHECK_HOME_PROFILE+x}" = x ] || \
     [ "${SK_EMACS_CHECK_SYSTEM_PROFILE+x}" = x ]; }; then
    printf '%s\n' \
        'preflight: candidate profile overrides require --batch-only' >&2
    exit 2
fi

home_profile=${SK_EMACS_CHECK_HOME_PROFILE:-$real_home/.guix-home/profile}
system_profile=${SK_EMACS_CHECK_SYSTEM_PROFILE:-/run/current-system/profile}

for profile in "$home_profile" "$system_profile"; do
    case $profile in
        /*) ;;
        *)
            printf 'preflight: candidate profile must be absolute: %s\n' \
                "$profile" >&2
            exit 2
            ;;
    esac
    if [ ! -d "$profile" ]; then
        printf 'preflight: candidate profile is not a directory: %s\n' \
            "$profile" >&2
        exit 2
    fi
done

if [ -x "$home_profile/bin/emacs" ]; then
    batch_emacs=$home_profile/bin/emacs
elif [ "$batch_only" -eq 0 ] && [ -x "$system_profile/bin/emacs" ]; then
    batch_emacs=$system_profile/bin/emacs
else
    printf 'preflight: candidate Home Emacs is not executable: %s\n' \
        "$home_profile/bin/emacs" >&2
    exit 2
fi

candidate_path="$home_profile/bin:$system_profile/bin:$system_profile/sbin"
candidate_emacsloadpath="$home_profile/share/emacs/site-lisp:$system_profile/share/emacs/site-lisp:"

if [ "$batch_only" -eq 1 ]; then
    export PATH="$candidate_path"
else
    export PATH="$real_home/.guix-home/profile/bin:/run/privileged/bin:$real_home/.config/guix/current/bin:$real_home/.guix-profile/bin:/run/current-system/profile/bin:/run/current-system/profile/sbin:${PATH:-}"
fi
export EMACSLOADPATH="$candidate_emacsloadpath"

required_commands='chmod cksum cp env git ln mkdir mktemp rm sort timeout'
if [ "$batch_only" -eq 0 ]; then
    required_commands="$required_commands emacsclient sed"
fi
for command in $required_commands; do
    if ! command -v "$command" >/dev/null 2>&1; then
        printf 'preflight: missing %s\n' "$command" >&2
        exit 2
    fi
done

live_expression_file="$repo/tests/emacs/live-check.el"
early_init="$repo/emacs/early-init.el"
batch_bootstrap="$repo/tests/emacs/batch-bootstrap.el"
batch_checks="$repo/tests/emacs/batch-check.el"
backend_checks="$repo/tests/emacs/backend-check.el"
guix_lisp_shell="$repo/scripts/guix-lisp-shell"
clojure_project="$repo/scripts/clojure-project"
racket_project="$repo/scripts/racket-project"
fennel_project="$repo/scripts/fennel-project"

for file in "$live_expression_file" "$early_init" "$batch_bootstrap" \
    "$batch_checks" "$backend_checks" "$guix_lisp_shell" "$clojure_project" \
    "$racket_project" "$fennel_project"; do
    if [ ! -r "$file" ]; then
        printf 'preflight: unreadable %s\n' "$file" >&2
        exit 2
    fi
done

repository_state() {
    printf '%s\n' '== status =='
    git -C "$repo" status --porcelain=v1 --untracked-files=all
    printf '%s\n' '== worktree diff =='
    git -C "$repo" diff --no-ext-diff --binary
    printf '%s\n' '== index diff =='
    git -C "$repo" diff --cached --no-ext-diff --binary
    printf '%s\n' '== untracked content =='
    git -C "$repo" ls-files --others --exclude-standard | sort |
        while IFS= read -r relative; do
            [ -n "$relative" ] || continue
            cksum "$repo/$relative" ||
                printf 'UNREADABLE %s\n' "$relative"
        done
}

repo_state_before=$(repository_state)

run_live_checks() {
    if [ "${SK_EMACS_CHECK_BREAK_LIVE:-0}" = 1 ]; then
        live_expression='(error "deliberate live negative control")'
    else
        live_expression="$(sed -n '1,$p' "$live_expression_file")"
    fi

    timeout 10 emacsclient \
        --socket-name=server \
        --alternate-editor=false \
        --eval "$live_expression"
    live_result=$?
    printf '\n'
    return "$live_result"
}

run_batch_checks() (
    set -eu

    sandbox="$(mktemp -d "${TMPDIR:-/tmp}/sk-emacs-check.XXXXXX")"
    trap 'rm -rf -- "$sandbox"' EXIT
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 129' HUP
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 130' INT
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 143' TERM

    source_root="$sandbox/source"
    isolated_home="$sandbox/home"
    isolated_tmp="$sandbox/tmp"
    isolated_cache="$sandbox/xdg/cache"
    isolated_config="$sandbox/xdg/config"
    isolated_data="$sandbox/xdg/data"
    isolated_state="$sandbox/xdg/state"
    isolated_runtime="$sandbox/xdg/runtime"

    mkdir -p "$source_root" "$isolated_home/.guix-home" "$isolated_tmp" \
        "$isolated_cache" "$isolated_config" "$isolated_data" \
        "$isolated_state" "$isolated_runtime" "$source_root/scripts"
    chmod 700 "$sandbox" "$isolated_home" "$isolated_tmp" "$isolated_runtime"

    # Under -Q Emacs neither discovers early-init.el nor the real Guix Home
    # profile.  Reproduce both pieces explicitly while keeping all mutable
    # state inside the disposable HOME.
    ln -s "$home_profile" "$isolated_home/.guix-home/profile"

    cp -R "$repo/emacs" "$source_root/emacs"
    cp -R "$repo/fixtures" "$source_root/fixtures"
    cp "$guix_lisp_shell" "$source_root/scripts/guix-lisp-shell"
    cp "$clojure_project" "$source_root/scripts/clojure-project"
    cp "$racket_project" "$source_root/scripts/racket-project"
    cp "$fennel_project" "$source_root/scripts/fennel-project"

    env -i \
        HOME="$isolated_home" \
        TMPDIR="$isolated_tmp" \
        XDG_CACHE_HOME="$isolated_cache" \
        XDG_CONFIG_HOME="$isolated_config" \
        XDG_DATA_HOME="$isolated_data" \
        XDG_STATE_HOME="$isolated_state" \
        XDG_RUNTIME_DIR="$isolated_runtime" \
        PATH="$PATH" \
        EMACSLOADPATH="$EMACSLOADPATH" \
        LANG=en_US.utf8 \
        LC_ALL=en_US.utf8 \
        SK_EMACS_CHECK_SOURCE_ROOT="$source_root" \
        SK_EMACS_CHECK_SANDBOX_ROOT="$sandbox" \
        SK_EMACS_CHECK_ORIGINAL_REPO="$repo" \
        SK_EMACS_CHECK_REAL_HOME="$real_home" \
        SK_EMACS_CHECK_HOME_PROFILE="$home_profile" \
        SK_EMACS_CHECK_SYSTEM_PROFILE="$system_profile" \
        SK_EMACS_CHECK_BATCH_EMACS="$batch_emacs" \
        SK_EMACS_CHECK_BREAK_BATCH="${SK_EMACS_CHECK_BREAK_BATCH:-0}" \
        SK_EMACS_CHECK_BREAK_WARNING="${SK_EMACS_CHECK_BREAK_WARNING:-0}" \
        timeout 120 "$batch_emacs" --batch -Q \
        --eval '(setq user-emacs-directory (file-name-as-directory (expand-file-name ".emacs.d" (getenv "HOME"))))' \
        --load "$batch_bootstrap" \
        --load "$source_root/emacs/early-init.el" \
        --eval '(setq flycheck-check-syntax-automatically nil)' \
        --load "$source_root/emacs/init.el" \
        --eval '(run-hooks (quote after-init-hook))' \
        --load "$batch_checks"
)

run_backend_checks() (
    set -eu

    sandbox="$(mktemp -d "${TMPDIR:-/tmp}/sk-emacs-backend-check.XXXXXX")"
    trap 'rm -rf -- "$sandbox"' EXIT
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 129' HUP
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 130' INT
    trap 'rm -rf -- "$sandbox"; trap - EXIT; exit 143' TERM

    source_root="$sandbox/source"
    isolated_home="$sandbox/home"
    isolated_tmp="$sandbox/tmp"
    isolated_cache="$sandbox/xdg/cache"
    isolated_config="$sandbox/xdg/config"
    isolated_data="$sandbox/xdg/data"
    isolated_state="$sandbox/xdg/state"
    isolated_runtime="$sandbox/xdg/runtime"

    mkdir -p "$source_root" "$isolated_home" "$isolated_tmp" \
        "$isolated_cache" "$isolated_config" "$isolated_data" \
        "$isolated_state" "$isolated_runtime"
    chmod 700 "$sandbox" "$isolated_home" "$isolated_tmp" "$isolated_runtime"

    cp -R "$repo/fixtures" "$source_root/fixtures"

    # GNU timeout runs COMMAND in a process group unless --foreground is
    # used.  TERM, then KILL, therefore reaches this disposable Emacs and
    # its Guile/SBCL descendants even if Emacs cannot run unwind cleanup.
    env -i \
        HOME="$isolated_home" \
        TMPDIR="$isolated_tmp" \
        XDG_CACHE_HOME="$isolated_cache" \
        XDG_CONFIG_HOME="$isolated_config" \
        XDG_DATA_HOME="$isolated_data" \
        XDG_STATE_HOME="$isolated_state" \
        XDG_RUNTIME_DIR="$isolated_runtime" \
        PATH="$PATH" \
        EMACSLOADPATH="$EMACSLOADPATH" \
        LANG=en_US.utf8 \
        LC_ALL=en_US.utf8 \
        GUILE_AUTO_COMPILE=0 \
        SK_EMACS_CHECK_SOURCE_ROOT="$source_root" \
        SK_EMACS_CHECK_SANDBOX_ROOT="$sandbox" \
        SK_EMACS_CHECK_BREAK_BACKEND="${SK_EMACS_CHECK_BREAK_BACKEND:-0}" \
        timeout --signal=TERM --kill-after=10 180 "$batch_emacs" --batch -Q \
        --eval '(setq user-emacs-directory (file-name-as-directory (expand-file-name ".emacs.d" (getenv "HOME"))))' \
        --load "$backend_checks"
)

printf '%s\n' '== live read-only checks =='
if [ "$batch_only" -eq 1 ]; then
    live_status=0
    printf '%s\n' 'live: SKIP (batch-only candidate validation)'
elif run_live_checks; then
    live_status=0
    printf '%s\n' 'live: PASS'
else
    live_status=$?
    printf 'live: FAIL (status %s)\n' "$live_status" >&2
fi

printf '%s\n' '== isolated batch checks =='
if run_batch_checks; then
    batch_status=0
    printf '%s\n' 'batch: PASS'
else
    batch_status=$?
    printf 'batch: FAIL (status %s)\n' "$batch_status" >&2
fi

printf '%s\n' '== isolated connected backend checks =='
if run_backend_checks; then
    backend_status=0
    printf '%s\n' 'backend: PASS'
else
    backend_status=$?
    printf 'backend: FAIL (status %s)\n' "$backend_status" >&2
fi

repo_state_after=$(repository_state)
if [ "$repo_state_before" = "$repo_state_after" ]; then
    repository_status=0
    printf '%s\n' 'repository state: unchanged'
else
    repository_status=1
    printf '%s\n' 'repository state: CHANGED' >&2
    printf '%s\n' '-- before --' "$repo_state_before" \
        '-- after --' "$repo_state_after" >&2
fi

if [ "$live_status" -eq 0 ] &&
   [ "$batch_status" -eq 0 ] &&
   [ "$backend_status" -eq 0 ] &&
   [ "$repository_status" -eq 0 ]; then
    printf '%s\n' 'emacs-check: PASS'
    exit 0
fi

printf 'emacs-check: FAIL (live=%s batch=%s backend=%s repository=%s)\n' \
    "$live_status" "$batch_status" "$backend_status" \
    "$repository_status" >&2
exit 1
