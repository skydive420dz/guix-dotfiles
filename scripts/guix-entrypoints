#!/bin/sh

set -u

usage() {
    printf 'Usage: %s check|plan|bootstrap\n' "$0" >&2
    exit 2
}

[ "$#" -eq 1 ] || usage
mode=$1
case $mode in
    check | plan | bootstrap) ;;
    *) usage ;;
esac

script_dir=$(CDPATH='' cd "$(dirname "$0")" && pwd -P) || exit 1
repo=$(CDPATH='' cd "$script_dir/.." && pwd -P) || exit 1
home=${HOME:-}

if [ -z "$home" ]; then
    printf 'guix-entrypoints: HOME is not set\n' >&2
    exit 2
fi

problems=0
fatal=0

report_parent_blocker() {
    target=$1
    name=$2
    probe=$(dirname "$target")

    while [ ! -e "$probe" ] && [ ! -L "$probe" ]; do
        next=$(dirname "$probe")
        [ "$next" != "$probe" ] || break
        probe=$next
    done

    if [ -L "$probe" ] && [ ! -e "$probe" ]; then
        printf 'guix-entrypoints: DANGLING parent for %s: %s\n' \
            "$name" "$probe" >&2
        problems=1
        fatal=1
        return 0
    fi

    if [ -e "$probe" ] && [ ! -d "$probe" ]; then
        printf 'guix-entrypoints: BLOCKED parent for %s: %s is not a directory\n' \
            "$name" "$probe" >&2
        problems=1
        fatal=1
        return 0
    fi

    return 1
}

inspect_link() {
    name=$1
    target=$2
    source=$3
    link_problems=0

    if [ ! -e "$source" ]; then
        printf 'guix-entrypoints: DANGLING source for %s: %s\n' \
            "$name" "$source" >&2
        problems=1
        fatal=1
        link_problems=1
    fi

    if report_parent_blocker "$target" "$name"; then
        return
    fi

    if [ -L "$target" ]; then
        actual=$(readlink "$target")
        if [ "$actual" != "$source" ]; then
            printf 'guix-entrypoints: WRONG %s: %s -> %s; expected -> %s\n' \
                "$name" "$target" "$actual" "$source" >&2
            problems=1
            link_problems=1
        fi
        if [ ! -e "$target" ]; then
            printf 'guix-entrypoints: DANGLING %s: %s -> %s\n' \
                "$name" "$target" "$actual" >&2
            problems=1
            link_problems=1
        fi
    elif [ -e "$target" ]; then
        printf 'guix-entrypoints: BLOCKED %s: %s exists and is not a symlink\n' \
            "$name" "$target" >&2
        problems=1
        fatal=1
        link_problems=1
    else
        printf 'guix-entrypoints: MISSING %s: %s; expected symlink -> %s\n' \
            "$name" "$target" "$source" >&2
        problems=1
        link_problems=1
    fi

    if [ "$link_problems" -eq 0 ]; then
        printf 'guix-entrypoints: OK %s: %s -> %s\n' \
            "$name" "$target" "$source"
    fi
}

inspect_all() {
    inspect_link \
        channels.scm \
        "$home/.config/guix/channels.scm" \
        "$repo/guix/channels.scm"
    inspect_link \
        home.scm \
        "$home/.config/guix/home.scm" \
        "$repo/guix/home/guixpc.scm"
    inspect_link \
        systems/guixpc.scm \
        "$home/.config/guix/systems/guixpc.scm" \
        "$repo/guix/systems/guixpc.scm"
}

install_link() {
    name=$1
    target=$2
    source=$3

    mkdir -p "$(dirname "$target")" || exit 1
    if [ -L "$target" ]; then
        actual=$(readlink "$target")
        if [ "$actual" = "$source" ] && [ -e "$target" ]; then
            return
        fi
        unlink "$target" || exit 1
    fi
    ln -s "$source" "$target" || exit 1
    printf 'guix-entrypoints: installed %s: %s -> %s\n' \
        "$name" "$target" "$source"
}

install_all() {
    install_link \
        channels.scm \
        "$home/.config/guix/channels.scm" \
        "$repo/guix/channels.scm"
    install_link \
        home.scm \
        "$home/.config/guix/home.scm" \
        "$repo/guix/home/guixpc.scm"
    install_link \
        systems/guixpc.scm \
        "$home/.config/guix/systems/guixpc.scm" \
        "$repo/guix/systems/guixpc.scm"
}

inspect_all

if [ "$mode" = check ]; then
    [ "$problems" -eq 0 ]
    exit $?
fi

if [ "$mode" = plan ]; then
    if [ "$fatal" -ne 0 ]; then
        printf 'guix-entrypoints: plan refused; blockers require manual repair\n' >&2
        exit 1
    fi
    if [ "$problems" -ne 0 ]; then
        printf '%s\n' \
            'guix-entrypoints: PLAN repairable entrypoints; no links were changed'
    else
        printf '%s\n' 'guix-entrypoints: PLAN entrypoints already match'
    fi
    exit 0
fi

if [ "$fatal" -ne 0 ]; then
    printf 'guix-entrypoints: bootstrap refused; no links were changed\n' >&2
    exit 1
fi

install_all
problems=0
fatal=0
inspect_all
[ "$problems" -eq 0 ]
