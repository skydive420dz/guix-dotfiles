#!/bin/sh
set -eu

repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)

if ! command -v shellcheck >/dev/null 2>&1; then
    printf 'shell-check: missing command: shellcheck\n' >&2
    exit 127
fi

shellcheck \
    "$repo/fixtures/shell/sample.sh" \
    "$repo/ranger/scope.sh" \
    "$repo/scripts/editor-tools-check" \
    "$repo/scripts/desktop-session-check" \
    "$repo/scripts/emacs-check" \
    "$repo/scripts/exwm-session" \
    "$repo/scripts/guix-build-gate" \
    "$repo/scripts/guix-entrypoints" \
    "$repo/scripts/guix-generation-retention" \
    "$repo/scripts/guix-reconfigure" \
    "$repo/scripts/shell-check" \
    "$repo/shell/bash_profile" \
    "$repo/shell/bashrc" \
    "$repo/shell/xinitrc" \
    "$repo/shell/zprofile" \
    "$repo/tests/exwm-session-check" \
    "$repo/tests/guix-build-gate-check" \
    "$repo/tests/guix-entrypoints-check" \
    "$repo/tests/guix-generation-retention-check" \
    "$repo/tests/guix-home-links-check" \
    "$repo/tests/guix-reconfigure-check"

"$repo/tests/exwm-session-check"
"$repo/tests/guix-build-gate-check"
"$repo/tests/guix-generation-retention-check"
"$repo/tests/guix-reconfigure-check"

printf '%s\n' 'shell-check: PASS'
