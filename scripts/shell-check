#!/bin/sh
set -eu

repo=$(CDPATH='' cd "$(dirname "$0")/.." && pwd -P)

case $# in
    0) strict=0 ;;
    1)
        [ "$1" = --strict ] || {
            printf 'usage: %s [--strict]\n' "$0" >&2
            exit 64
        }
        strict=1
        ;;
    *)
        printf 'usage: %s [--strict]\n' "$0" >&2
        exit 64
        ;;
esac

if ! command -v shellcheck >/dev/null 2>&1; then
    printf 'shell-check: missing command: shellcheck\n' >&2
    exit 127
fi

shellcheck \
    "$repo/fixtures/shell/sample.sh" \
    "$repo/ranger/scope.sh" \
    "$repo/scripts/editor-tools-check" \
    "$repo/scripts/desktop-audio-output-check" \
    "$repo/scripts/desktop-session-check" \
    "$repo/scripts/emacs-check" \
    "$repo/scripts/emacs-clojure-check" \
    "$repo/scripts/emacs-fennel-check" \
    "$repo/scripts/exwm-session" \
    "$repo/scripts/guix-bootstrap" \
    "$repo/scripts/guix-build-gate" \
    "$repo/scripts/guix-entrypoints" \
    "$repo/scripts/guix-generation-retention" \
    "$repo/scripts/guix-lisp-shell" \
    "$repo/scripts/clojure-project" \
    "$repo/scripts/clojure-project-check" \
    "$repo/scripts/lisp-project-check" \
    "$repo/scripts/guix-reconfigure" \
    "$repo/scripts/shell-check" \
    "$repo/shell/bash_profile" \
    "$repo/shell/bashrc" \
    "$repo/shell/xinitrc" \
    "$repo/shell/zprofile" \
    "$repo/tests/exwm-session-check" \
    "$repo/tests/desktop-audio-output-check" \
    "$repo/tests/desktop-policy-check" \
    "$repo/tests/emacs-fennel-check" \
    "$repo/tests/guix-bootstrap-check" \
    "$repo/tests/guix-build-gate-check" \
    "$repo/tests/guix-entrypoints-check" \
    "$repo/tests/guix-generation-retention-check" \
    "$repo/tests/guix-lisp-shell-check" \
    "$repo/tests/clojure-project-check" \
    "$repo/tests/lisp-project-check" \
    "$repo/tests/guix-home-links-check" \
    "$repo/tests/guix-package-ownership-check" \
    "$repo/tests/guix-reconfigure-check"

"$repo/tests/exwm-session-check"
"$repo/tests/desktop-audio-output-check"
"$repo/tests/desktop-policy-check"
"$repo/tests/emacs-performance-snapshot-check"
"$repo/tests/emacs-startup-attribution-check"
"$repo/tests/emacs-fennel-check"
"$repo/tests/guix-bootstrap-check"
"$repo/tests/guix-build-gate-check"
"$repo/tests/guix-entrypoints-check"
"$repo/tests/guix-generation-retention-check"
if command -v guile >/dev/null 2>&1; then
    "$repo/tests/guix-home-links-check"
else
    if [ "$strict" -eq 1 ]; then
        printf '%s\n' 'shell-check: strict mode requires guile' >&2
        exit 127
    fi
    printf '%s\n' 'SKIP: Guix Home link fixture (guile unavailable)'
fi
"$repo/tests/guix-lisp-shell-check"
"$repo/tests/clojure-project-check"
"$repo/tests/lisp-project-check"
"$repo/tests/guix-package-ownership-check"
"$repo/tests/guix-reconfigure-check"

printf '%s\n' 'shell-check: PASS'
