#!/bin/sh

set -eu

fail() {
    printf 'clojure-project-check: %s\n' "$1" >&2
    exit 1
}

if [ "${SK_CLOJURE_PROJECT_CHECK_INNER:-0}" = 1 ]; then
    [ "$#" -eq 0 ] || fail 'internal runner received arguments'
    project=${SK_CLOJURE_PROJECT_CHECK_PROJECT:?}
    project_command=${SK_CLOJURE_PROJECT_CHECK_COMMAND:?}

    make_project() {
        CLOJURE_PROJECT=$project_command \
            make --no-print-directory -s -C "$project" "$1"
    }

    expected_classpath=$GUIX_ENVIRONMENT/share/java/clojure.jar:$project/src:$project/test
    actual_classpath=$("$project_command" classpath "$project")
    [ "$actual_classpath" = "$expected_classpath" ] || \
        fail 'direct classpath differs from the Guix JAR plus src/test'

    make_classpath=$(make_project classpath)
    [ "$make_classpath" = "$expected_classpath" ] || \
        fail 'Make/LSP classpath differs from the direct project classpath'

    "$project_command" format-check "$project"
    "$project_command" lint "$project"

    result=$(make_project eval)
    [ "$result" = 42 ] || fail "evaluation returned $result instead of 42"
    printf '%s\n' 'clojure-project-check: evaluation: 42'

    make_project test

    result=$(make_project reload)
    [ "$result" = 42 ] || fail "reload returned $result instead of 42"
    printf '%s\n' 'clojure-project-check: reload: 42'

    source_file=$project/src/sk/fixture/core.clj
    test_file=$project/test/sk/fixture/core_test.clj
    saved_source=$TMPDIR/core.clj.saved
    saved_test=$TMPDIR/core_test.clj.saved
    negative_output=$TMPDIR/negative.out
    cp "$source_file" "$saved_source"
    cp "$test_file" "$saved_test"

    cp "$project/negative/unformatted.clj" "$source_file"
    if "$project_command" format-check "$project" \
        >"$negative_output" 2>&1; then
        fail 'unformatted negative control unexpectedly passed'
    fi
    cp "$saved_source" "$source_file"
    printf '%s\n' 'clojure-project-check: format negative control: PASS'

    cp "$project/negative/lint-error.clj" "$source_file"
    if "$project_command" lint "$project" >"$negative_output" 2>&1; then
        fail 'lint negative control unexpectedly passed'
    fi
    cp "$saved_source" "$source_file"
    printf '%s\n' 'clojure-project-check: lint negative control: PASS'

    cp "$project/negative/failing-test.clj" "$test_file"
    if make_project test >"$negative_output" 2>&1; then
        fail 'test negative control unexpectedly passed'
    fi
    cp "$saved_test" "$test_file"
    printf '%s\n' 'clojure-project-check: test negative control: PASS'

    make_project check
    printf '%s\n' 'clojure-project-check: make check: PASS'

    for artifact in \
        "$project/.cpcache" \
        "$project/.lsp/.cache" \
        "$project/.clj-kondo/.cache" \
        "$project/target"; do
        [ ! -e "$artifact" ] || fail "project-local artifact appeared: $artifact"
    done
    exit 0
fi

usage() {
    printf 'usage: %s [REPOSITORY]\n' "$0" >&2
    exit 64
}

case $# in
    0) repository_input=$(dirname "$0")/.. ;;
    1) repository_input=$1 ;;
    *) usage ;;
esac

if ! repository=$(CDPATH='' cd -- "$repository_input" 2>/dev/null && pwd -P); then
    printf 'clojure-project-check: repository is not a directory: %s\n' \
        "$repository_input" >&2
    exit 66
fi

fixture=$repository/fixtures/clojure
project_command=$repository/scripts/clojure-project
lisp_shell=$repository/scripts/guix-lisp-shell

for path in "$fixture/.projectile" "$fixture/Makefile" "$fixture/deps.edn" \
    "$fixture/.lsp/config.edn" "$fixture/.clj-kondo/config.edn" \
    "$fixture/.cljfmt.edn" "$fixture/.gitignore" \
    "$fixture/src/sk/fixture/core.clj" \
    "$fixture/test/sk/fixture/core_test.clj" \
    "$fixture/test/sk/fixture/test_runner.clj" \
    "$fixture/negative/unformatted.clj" \
    "$fixture/negative/lint-error.clj" \
    "$fixture/negative/failing-test.clj" "$project_command"; do
    if [ ! -r "$path" ]; then
        printf 'clojure-project-check: unreadable input: %s\n' "$path" >&2
        exit 66
    fi
done

if [ ! -x "$project_command" ]; then
    printf 'clojure-project-check: input is not executable: %s\n' \
        "$project_command" >&2
    exit 66
fi

for command in chmod cksum cp dirname env make mkdir mktemp rm; do
    if ! command -v "$command" >/dev/null 2>&1; then
        printf 'clojure-project-check: missing command: %s\n' "$command" >&2
        exit 127
    fi
done

fixture_state() {
    (
        cd "$fixture"
        cksum \
            .projectile \
            .gitignore \
            .cljfmt.edn \
            .clj-kondo/config.edn \
            .lsp/config.edn \
            Makefile \
            deps.edn \
            negative/failing-test.clj \
            negative/lint-error.clj \
            negative/unformatted.clj \
            src/sk/fixture/core.clj \
            test/sk/fixture/core_test.clj \
            test/sk/fixture/test_runner.clj
    )
}

before=$(fixture_state)
sandbox=$(mktemp -d "${TMPDIR:-/tmp}/sk-clojure-project-check.XXXXXX")
sandbox=$(CDPATH='' cd "$sandbox" && pwd -P)
cleanup() {
    rm -rf -- "$sandbox"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

isolated_home=$sandbox/home
isolated_tmp=$sandbox/tmp
isolated_cache=$sandbox/xdg/cache
isolated_config=$sandbox/xdg/config
isolated_data=$sandbox/xdg/data
isolated_state=$sandbox/xdg/state
isolated_runtime=$sandbox/xdg/runtime
project=$sandbox/project

mkdir -p "$isolated_home" "$isolated_tmp" "$isolated_cache" \
    "$isolated_config" "$isolated_data" "$isolated_state" \
    "$isolated_runtime" "$project"
chmod 700 "$sandbox" "$isolated_home" "$isolated_tmp" "$isolated_runtime"
cp -R "$fixture/." "$project/"

printf '%s\n' '== Clojure project =='
set -- env \
    "HOME=$isolated_home" \
    "TMPDIR=$isolated_tmp" \
    "XDG_CACHE_HOME=$isolated_cache" \
    "XDG_CONFIG_HOME=$isolated_config" \
    "XDG_DATA_HOME=$isolated_data" \
    "XDG_STATE_HOME=$isolated_state" \
    "XDG_RUNTIME_DIR=$isolated_runtime" \
    "LANG=C" \
    "LC_ALL=C" \
    "TZ=UTC" \
    "SK_CLOJURE_PROJECT_CHECK_INNER=1" \
    "SK_CLOJURE_PROJECT_CHECK_PROJECT=$project" \
    "SK_CLOJURE_PROJECT_CHECK_COMMAND=$project_command" \
    "$repository/scripts/clojure-project-check"

if [ -n "${GUIX_ENVIRONMENT:-}" ] && \
    [ -r "$GUIX_ENVIRONMENT/share/java/clojure.jar" ]; then
    "$@"
else
    home=${HOME:?HOME must be set}
    guix=${GUIX:-$home/.config/guix/current/bin/guix}
    if [ ! -x "$guix" ]; then
        printf 'clojure-project-check: canonical Guix is not executable: %s\n' \
            "$guix" >&2
        exit 69
    fi
    if [ ! -r "$lisp_shell" ] || [ ! -x "$lisp_shell" ]; then
        printf 'clojure-project-check: Guix shell wrapper is unavailable: %s\n' \
            "$lisp_shell" >&2
        exit 66
    fi
    HOME=$isolated_home \
    TMPDIR=$isolated_tmp \
    XDG_CACHE_HOME=$isolated_cache \
    XDG_CONFIG_HOME=$isolated_config \
    XDG_DATA_HOME=$isolated_data \
    XDG_STATE_HOME=$isolated_state \
    XDG_RUNTIME_DIR=$isolated_runtime \
    GUIX=$guix \
        "$lisp_shell" jvm -- "$@"
fi

after=$(fixture_state)
[ "$after" = "$before" ] || fail 'source fixture changed during isolated run'

printf '%s\n' 'clojure-project-check: PASS'
