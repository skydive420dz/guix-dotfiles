#!/bin/sh
set -eu

program=${0##*/}

usage() {
    printf 'usage: %s inventory|plan|estimate|verify|rollback-drill\n' \
        "$program" >&2
    exit 64
}

fail() {
    printf '%s: FAIL: %s\n' "$program" "$*" >&2
    exit 1
}

[ "$#" -eq 1 ] || usage
action=$1
case $action in
    inventory | plan | estimate | verify | rollback-drill) ;;
    *) usage ;;
esac

script_dir=$(CDPATH='' cd "$(dirname "$0")" && pwd -P)
repo=$(CDPATH='' cd "$script_dir/.." && pwd -P)
pins=${GUIX_RETENTION_PINS:-$repo/guix/machines/guixpc/generation-pins.tsv}
root=${GUIX_RETENTION_ROOT:-/}
retention_user=${GUIX_RETENTION_USER:-$(id -un)}
retention_home=${GUIX_RETENTION_HOME:-${HOME:?HOME must be set}}
estimator_override=${GUIX_RETENTION_ESTIMATOR_HELPER:-}
estimator_scheme=$repo/scripts/guix-generation-retention-estimator.scm
estimator_guix=${GUIX_RETENTION_GUIX:-$retention_home/.config/guix/current/bin/guix}

case $root in
    /*) ;;
    *) fail "GUIX_RETENTION_ROOT must be absolute: $root" ;;
esac
root=${root%/}
[ -n "$root" ] || root=/
[ -d "$root" ] || fail "GUIX_RETENTION_ROOT is not a directory: $root"
root=$(CDPATH='' cd "$root" && pwd -P) ||
    fail "cannot canonicalize GUIX_RETENTION_ROOT: $root"

root_path() (
    rp_logical=$1
    if [ "$root" = / ]; then
        printf '%s\n' "$rp_logical"
    else
        printf '%s%s\n' "$root" "$rp_logical"
    fi
)

canonical_path() (
    cp_source=$1
    [ -e "$cp_source" ] || exit 1
    cp_resolved=$(readlink -f "$cp_source") || exit 1
    if [ "$root" != / ]; then
        case $cp_resolved in
            "$root"/*) cp_resolved=${cp_resolved#"$root"} ;;
            *) exit 1 ;;
        esac
    fi
    printf '%s\n' "$cp_resolved"
)

validate_store_target() {
    vst_kind=$1
    vst_target=$2
    case $vst_target in
        /gnu/store/*) ;;
        *) fail "$vst_kind target is outside /gnu/store: $vst_target" ;;
    esac
    vst_name=${vst_target#/gnu/store/}
    case $vst_name in
        '' | */*) fail "invalid $vst_kind store target: $vst_target" ;;
    esac
    vst_hash=${vst_name%%-*}
    case $vst_hash in
        *[!0-9a-z]*) fail "invalid $vst_kind store hash: $vst_target" ;;
    esac
    [ "${#vst_hash}" -eq 32 ] ||
        fail "invalid $vst_kind store hash length: $vst_target"
    case $vst_kind:$vst_name in
        system:*-system | home:*-home | pull:*-profile) ;;
        *) fail "unexpected $vst_kind store suffix: $vst_target" ;;
    esac
}

work=$(mktemp -d "${TMPDIR:-/tmp}/guix-generation-retention.XXXXXX")
trap 'rm -rf -- "$work"' EXIT HUP INT TERM
tab=$(printf '\t')
inventory=$work/inventory.tsv
currents=$work/currents.tsv
normalized_pins=$work/pins.tsv
protected=$work/protected.tsv
candidates=$work/candidates.tsv
policy_input=$work/policy-input.tsv
policy_rows=$work/policy-rows.tsv
candidate_targets=$work/candidate-targets.txt
retained_targets=$work/retained-targets.txt
ignored_roots=$work/ignored-roots.txt
helper_output=$work/helper-output.tsv
snapshot_before=$work/snapshot-before.tsv
snapshot_after=$work/snapshot-after.tsv
: >"$inventory"
: >"$currents"
: >"$normalized_pins"
: >"$protected"
: >"$candidates"

collect_generations() {
    cg_kind=$1
    cg_directory=$2
    cg_prefix=$3
    cg_unsorted=$work/$cg_kind.unsorted
    : >"$cg_unsorted"

    for cg_link in "$cg_directory"/"$cg_prefix"[0-9]*-link; do
        [ -L "$cg_link" ] || continue
        cg_name=${cg_link##*/}
        cg_generation=${cg_name#"$cg_prefix"}
        cg_generation=${cg_generation%-link}
        case $cg_generation in
            '' | *[!0-9]*)
                fail "invalid $cg_kind generation link name: $cg_link"
                ;;
        esac
        cg_target=$(canonical_path "$cg_link") ||
            fail "dangling or out-of-root $cg_kind generation: $cg_link"
        validate_store_target "$cg_kind" "$cg_target"
        printf '%s\t%s\t%s\n' "$cg_kind" "$cg_generation" "$cg_target" \
            >>"$cg_unsorted"
    done

    [ -s "$cg_unsorted" ] || fail "no $cg_kind generations found in $cg_directory"
    if ! awk -F '\t' '
        seen[$1 FS $2]++ { exit 1 }
    ' "$cg_unsorted"; then
        fail "duplicate $cg_kind generation numbers"
    fi
    sort -t "$tab" -k2,2n "$cg_unsorted" >>"$inventory"
}

record_current() {
    rc_kind=$1
    rc_pointer=$2
    rc_prefix=$3
    [ -L "$rc_pointer" ] || fail "missing $rc_kind current pointer: $rc_pointer"
    rc_link=$(readlink "$rc_pointer") || fail "cannot read $rc_kind current pointer"
    rc_name=${rc_link##*/}
    rc_generation=${rc_name#"$rc_prefix"}
    rc_generation=${rc_generation%-link}
    case $rc_generation in
        '' | *[!0-9]* | "$rc_name")
            fail "unexpected $rc_kind current pointer target: $rc_link"
            ;;
    esac
    rc_target=$(canonical_path "$rc_pointer") ||
        fail "dangling or out-of-root $rc_kind current pointer: $rc_pointer"
    rc_recorded=$(awk -F '\t' -v kind="$rc_kind" -v generation="$rc_generation" '
        $1 == kind && $2 == generation { print $3 }
    ' "$inventory")
    [ -n "$rc_recorded" ] ||
        fail "$rc_kind current generation $rc_generation is absent from inventory"
    [ "$rc_recorded" = "$rc_target" ] ||
        fail "$rc_kind current pointer target mismatch: $rc_recorded != $rc_target"
    printf '%s\t%s\t%s\n' "$rc_kind" "$rc_generation" "$rc_target" \
        >>"$currents"
}

validate_pins() {
    [ -r "$pins" ] || fail "pin file is not readable: $pins"
    if ! awk -F '\t' '
        /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
        NF != 5 { exit 1 }
    ' "$pins"; then
        fail "pin file must contain exactly five tab-separated fields"
    fi

    while IFS="$tab" read -r vp_kind vp_generation vp_expected vp_role vp_reason; do
        case $vp_kind in
            '' | \#*) continue ;;
            system | home | pull) ;;
            *) fail "unknown pin kind: $vp_kind" ;;
        esac
        case $vp_generation in
            '' | *[!0-9]*) fail "invalid pinned generation: $vp_kind $vp_generation" ;;
        esac
        case $vp_role in
            promotion-rollback | preferred-rollback | emergency-rollback | last-known-good) ;;
            *) fail "unknown pin role: $vp_kind $vp_generation $vp_role" ;;
        esac
        [ -n "$vp_reason" ] || fail "pin reason is empty: $vp_kind $vp_generation"
        validate_store_target "$vp_kind" "$vp_expected"
        vp_actual=$(awk -F '\t' -v kind="$vp_kind" -v generation="$vp_generation" '
            $1 == kind && $2 == generation { print $3 }
        ' "$inventory")
        [ -n "$vp_actual" ] ||
            fail "pinned generation is absent: $vp_kind $vp_generation"
        [ "$vp_actual" = "$vp_expected" ] ||
            fail "pinned target mismatch for $vp_kind $vp_generation: $vp_actual != $vp_expected"
        printf '%s\t%s\t%s\t%s\t%s\n' \
            "$vp_kind" "$vp_generation" "$vp_expected" "$vp_role" "$vp_reason" \
            >>"$normalized_pins"
    done <"$pins"

    [ -s "$normalized_pins" ] || fail "pin file contains no pins"
    if ! awk -F '\t' '
        seen[$1 FS $2]++ { exit 1 }
    ' "$normalized_pins"; then
        fail "duplicate generation pin"
    fi
    for vp_required_kind in system home pull; do
        vp_promotion_count=$(awk -F '\t' -v kind="$vp_required_kind" '$1 == kind && $4 == "promotion-rollback" { n++ } END { print n + 0 }' "$normalized_pins")
        [ "$vp_promotion_count" -eq 1 ] ||
            fail "$vp_required_kind requires exactly one promotion rollback pin"
        vp_preferred_count=$(awk -F '\t' -v kind="$vp_required_kind" '$1 == kind && $4 == "preferred-rollback" { n++ } END { print n + 0 }' "$normalized_pins")
        [ "$vp_preferred_count" -eq 1 ] ||
            fail "$vp_required_kind requires exactly one preferred rollback pin"
    done
}

prepare_state() {
    ps_system_profiles=$(root_path /var/guix/profiles)
    ps_user_profiles=$(root_path "/var/guix/profiles/per-user/$retention_user")
    collect_generations system "$ps_system_profiles" system-
    collect_generations home "$ps_user_profiles" guix-home-
    collect_generations pull "$ps_user_profiles" current-guix-
    record_current system "$ps_system_profiles/system" system-
    record_current home "$ps_user_profiles/guix-home" guix-home-
    record_current pull "$ps_user_profiles/current-guix" current-guix-

    ps_system_current=$(awk -F '\t' '$1 == "system" { print $3 }' "$currents")
    ps_runtime_current_path=$(root_path /run/current-system)
    ps_runtime_current=$(canonical_path "$ps_runtime_current_path") ||
        fail "missing or invalid runtime current System: $ps_runtime_current_path"
    [ "$ps_runtime_current" = "$ps_system_current" ] ||
        fail "System profile and /run/current-system differ: $ps_system_current != $ps_runtime_current"

    ps_booted_path=$(root_path /run/booted-system)
    booted_target=$(canonical_path "$ps_booted_path") ||
        fail "missing or invalid booted System: $ps_booted_path"
    validate_store_target system "$booted_target"
    ps_booted_roots=$(awk -F '\t' -v target="$booted_target" '
        $1 == "system" && $3 == target { n++ } END { print n + 0 }
    ' "$inventory")
    [ "$ps_booted_roots" -gt 0 ] ||
        fail "booted System has no retained generation root: $booted_target"

    ps_config_current=$retention_home/.config/guix/current
    ps_config_target=$(canonical_path "$ps_config_current") ||
        fail "missing or invalid current Guix profile: $ps_config_current"
    ps_pull_current=$(awk -F '\t' '$1 == "pull" { print $3 }' "$currents")
    [ "$ps_config_target" = "$ps_pull_current" ] ||
        fail "current Guix link and pull profile differ: $ps_config_target != $ps_pull_current"

    validate_pins
    cut -f1,2 "$normalized_pins" >"$protected"
    cut -f1,2 "$currents" >>"$protected"
    sort -u "$protected" -o "$protected"

    awk -F '\t' '
        {
            row[NR] = $0
            key = $1 FS $3
            if ($2 + 0 > newest[key] + 0)
                newest[key] = $2
        }
        END {
            for (i = 1; i <= NR; i++) {
                split(row[i], field, FS)
                key = field[1] FS field[3]
                if (field[2] + 0 < newest[key] + 0)
                    print row[i]
            }
        }
    ' "$inventory" >"$work/duplicates.tsv"
    awk -F '\t' '
        NR == FNR { protected[$1 FS $2] = 1; next }
        !protected[$1 FS $2]
    ' "$protected" "$work/duplicates.tsv" >"$candidates"

    ps_booted_survivors=$(awk -F '\t' -v target="$booted_target" '
        NR == FNR { candidate[$1 FS $2] = 1; next }
        $1 == "system" && $3 == target && !candidate[$1 FS $2] { n++ }
        END { print n + 0 }
    ' "$candidates" "$inventory")
    [ "$ps_booted_survivors" -gt 0 ] ||
        fail "plan would remove every generation root for the booted System"
}

snapshot_kind() {
    sk_output=$1
    sk_kind=$2
    sk_directory=$3
    sk_prefix=$4

    for sk_link in "$sk_directory"/"$sk_prefix"[0-9]*-link; do
        [ -L "$sk_link" ] || continue
        sk_name=${sk_link##*/}
        sk_generation=${sk_name#"$sk_prefix"}
        sk_generation=${sk_generation%-link}
        sk_raw=$(readlink "$sk_link") ||
            fail "cannot snapshot $sk_kind generation $sk_generation"
        sk_target=$(canonical_path "$sk_link") ||
            fail "cannot snapshot $sk_kind generation $sk_generation target"
        printf 'generation\t%s\t%s\t%s\t%s\n' \
            "$sk_kind" "$sk_generation" "$sk_raw" "$sk_target" >>"$sk_output"
    done
}

snapshot_pointer() {
    sp_output=$1
    sp_name=$2
    sp_path=$3
    [ -L "$sp_path" ] || fail "cannot snapshot missing pointer: $sp_path"
    sp_raw=$(readlink "$sp_path") || fail "cannot read pointer: $sp_path"
    sp_target=$(canonical_path "$sp_path") ||
        fail "cannot resolve pointer: $sp_path"
    printf 'pointer\t%s\t%s\t%s\n' \
        "$sp_name" "$sp_raw" "$sp_target" >>"$sp_output"
}

snapshot_generation_state() {
    sgs_output=$1
    sgs_unsorted=$work/snapshot-unsorted.tsv
    : >"$sgs_unsorted"

    snapshot_kind "$sgs_unsorted" system "$ps_system_profiles" system-
    snapshot_kind "$sgs_unsorted" home "$ps_user_profiles" guix-home-
    snapshot_kind "$sgs_unsorted" pull "$ps_user_profiles" current-guix-
    snapshot_pointer "$sgs_unsorted" system-profile "$ps_system_profiles/system"
    snapshot_pointer "$sgs_unsorted" runtime-current \
        "$(root_path /run/current-system)"
    snapshot_pointer "$sgs_unsorted" runtime-booted \
        "$(root_path /run/booted-system)"
    snapshot_pointer "$sgs_unsorted" home-profile "$ps_user_profiles/guix-home"
    snapshot_pointer "$sgs_unsorted" pull-profile \
        "$ps_user_profiles/current-guix"
    snapshot_pointer "$sgs_unsorted" user-current \
        "$retention_home/.config/guix/current"
    sgs_pin_record=$(sha256sum "$pins") ||
        fail "cannot hash pin manifest: $pins"
    sgs_pin_hash=${sgs_pin_record%% *}
    case $sgs_pin_hash in
        '' | *[!0-9a-f]*) fail "invalid pin-manifest SHA256: $sgs_pin_hash" ;;
    esac
    [ "${#sgs_pin_hash}" -eq 64 ] ||
        fail "invalid pin-manifest SHA256 length: $sgs_pin_hash"
    printf 'pins\t%s\n' "$sgs_pin_hash" >>"$sgs_unsorted"
    LC_ALL=C sort "$sgs_unsorted" >"$sgs_output"
}

prepare_estimate_policy() {
    : >"$policy_input"
    {
        awk -F '\t' '{
            printf "generation\t%s\t%s\t%s\n", $1, $2, $3
        }' "$inventory"
        awk -F '\t' '{
            printf "current\t%s\t%s\t%s\n", $1, $2, $3
        }' "$currents"
        awk -F '\t' '{
            printf "pin\t%s\t%s\t%s\t%s\n", $1, $2, $3, $4
        }' "$normalized_pins"
        printf 'booted\t%s\n' "$booted_target"
    } >>"$policy_input"

    awk -F '\t' '
        function add_reason(key, value, current) {
            current = reason[key]
            if (current == "")
                reason[key] = value
            else if (index("," current ",", "," value ",") == 0)
                reason[key] = current "," value
        }
        $1 == "generation" {
            row_kind[++rows] = $2
            row_generation[rows] = $3 + 0
            row_target[rows] = $4
            key = $2 SUBSEP $4
            present[key] = 1
            target_links[key]++
            if (($3 + 0) > newest[key])
                newest[key] = $3 + 0
            next
        }
        $1 == "current" {
            current_generation[$2] = $3 + 0
            current_target[$2] = $4
            add_reason("link" SUBSEP $2 SUBSEP ($3 + 0), "current")
            next
        }
        $1 == "pin" {
            pinned[$2 SUBSEP $4] = 1
            add_reason("link" SUBSEP $2 SUBSEP ($3 + 0), "pin-" $5)
            next
        }
        $1 == "booted" {
            booted = $2
            next
        }
        END {
            kinds[1] = "system"
            kinds[2] = "home"
            kinds[3] = "pull"

            for (i = 1; i <= 3; i++) {
                kind = kinds[i]
                key = kind SUBSEP current_target[kind]
                retained[key] = 1
                add_reason("closure" SUBSEP key, "current")

                if (kind == "system" && booted != current_target[kind]) {
                    key = kind SUBSEP booted
                    retained[key] = 1
                    add_reason("closure" SUBSEP key, "booted")
                }

                for (slot = 1; slot <= 5; slot++) {
                    best_key = ""
                    best_generation = -1
                    for (key in present) {
                        split(key, field, SUBSEP)
                        if (field[1] != kind || selected[key])
                            continue
                        if (field[2] == current_target[kind])
                            continue
                        if (kind == "system" && field[2] == booted)
                            continue
                        if (newest[key] > best_generation) {
                            best_key = key
                            best_generation = newest[key]
                        }
                    }
                    if (best_key == "")
                        break
                    selected[best_key] = 1
                    retained[best_key] = 1
                    add_reason("closure" SUBSEP best_key,
                               "newest-additional")
                }
            }

            for (key in pinned) {
                retained[key] = 1
                add_reason("closure" SUBSEP key, "pin")
            }

            for (key in present) {
                split(key, field, SUBSEP)
                state = retained[key] ? "retain" : "candidate"
                tags = reason["closure" SUBSEP key]
                if (tags == "")
                    tags = "outside-floor"
                printf "closure\t%s\t%d\t%s\t%s\t%s\n",
                       field[1], newest[key], field[2], state, tags
            }

            for (i = 1; i <= rows; i++) {
                kind = row_kind[i]
                generation = row_generation[i]
                target = row_target[i]
                key = kind SUBSEP target
                link_key = "link" SUBSEP kind SUBSEP generation

                if (kind == "system" && target == booted) {
                    if (target_links[key] > 1)
                        add_reason(link_key, "booted-ambiguous")
                    else if (booted != current_target[kind])
                        add_reason(link_key, "booted")
                }

                if (retained[key] && generation == newest[key])
                    add_reason(link_key, "closure-survivor")

                tags = reason[link_key]
                if (tags != "")
                    printf "retain\t%s\t%d\t%s\t%s\n",
                           kind, generation, target, tags
                else if (retained[key])
                    printf "candidate\t%s\t%d\t%s\tduplicate-retained-closure\n",
                           kind, generation, target
                else
                    printf "candidate\t%s\t%d\t%s\tunretained-closure\n",
                           kind, generation, target
            }
        }
    ' "$policy_input" | LC_ALL=C sort -t "$tab" \
        -k1,1 -k2,2 -k3,3n -k4,4 >"$policy_rows"

    awk -F '\t' '
        $1 == "candidate" && $5 == "unretained-closure" { print $4 }
    ' "$policy_rows" | LC_ALL=C sort -u >"$candidate_targets"
    awk -F '\t' '
        $1 == "closure" && $5 == "retain" { print $4 }
    ' "$policy_rows" | LC_ALL=C sort -u >"$retained_targets"

    : >"$ignored_roots"
    while IFS="$tab" read -r pep_record pep_kind pep_generation \
        pep_target pep_class; do
        [ "$pep_record" = candidate ] || continue
        : "$pep_target" "$pep_class"
        case $pep_kind in
            system)
                pep_path=$ps_system_profiles/system-$pep_generation-link
                ;;
            home)
                pep_path=$ps_user_profiles/guix-home-$pep_generation-link
                ;;
            pull)
                pep_path=$ps_user_profiles/current-guix-$pep_generation-link
                ;;
            *)
                fail "unexpected estimate kind: $pep_kind"
                ;;
        esac
        printf '%s\n' "$pep_path" >>"$ignored_roots"
    done <"$policy_rows"
    LC_ALL=C sort -u "$ignored_roots" -o "$ignored_roots"
}

validate_helper_output() {
    vho_file=$1
    if ! awk -F '\t' '
        BEGIN { valid = 1 }
        $1 == "helper-schema" && NF == 2 {
            schemas++
            valid = valid && ($2 == "p5.1-store-estimate/v1")
            next
        }
        $1 == "known-root" && NF == 4 {
            roots++
            next
        }
        $1 == "estimate" && NF == 5 {
            estimates[$2]++
            if ($3 !~ /^[0-9]+$/ || $4 !~ /^[0-9]+$/)
                valid = 0
            counts[$2] = $3
            bytes[$2] = $4
            semantics[$2] = $5
            next
        }
        $1 == "coverage" && NF == 3 {
            coverage[$2]++
            next
        }
        $1 == "helper-status" && NF == 2 {
            statuses++
            valid = valid && ($2 == "PASS")
            next
        }
        { valid = 0 }
        END {
            required[1] = "candidate-closure-union"
            required[2] = "candidate-exclusive-vs-policy"
            required[3] = "candidate-exclusive-vs-persistent-known-roots"
            required[4] = "guaranteed-reclaimable"
            for (i = 1; i <= 4; i++)
                if (estimates[required[i]] != 1)
                    valid = 0
            if (semantics["candidate-closure-union"] != "measurement" ||
                semantics["candidate-exclusive-vs-policy"] != "forward-references-only" ||
                semantics["candidate-exclusive-vs-persistent-known-roots"] != "forward-references-only" ||
                semantics["guaranteed-reclaimable"] != "lower-bound" ||
                counts["guaranteed-reclaimable"] != "0" ||
                bytes["guaranteed-reclaimable"] != "0")
                valid = 0
            persistent_count = counts["candidate-exclusive-vs-persistent-known-roots"]
            policy_count = counts["candidate-exclusive-vs-policy"]
            candidate_count = counts["candidate-closure-union"]
            persistent_bytes = bytes["candidate-exclusive-vs-persistent-known-roots"]
            policy_bytes = bytes["candidate-exclusive-vs-policy"]
            candidate_bytes = bytes["candidate-closure-union"]
            if (persistent_count > policy_count ||
                policy_count > candidate_count ||
                persistent_bytes > policy_bytes ||
                policy_bytes > candidate_bytes)
                valid = 0
            if (coverage["persistent-roots"] != 1 ||
                coverage["gc-derivation-policy"] != 1 ||
                coverage["process-roots"] != 1 ||
                coverage["temporary-roots"] != 1 ||
                coverage["filesystem-allocation"] != 1)
                valid = 0
            exit !(valid && schemas == 1 && statuses == 1)
        }
    ' "$vho_file"; then
        fail "estimator helper returned malformed or incomplete output"
    fi
}

run_estimator_helper() {
    : >"$helper_output"
    if [ -n "$estimator_override" ]; then
        [ -x "$estimator_override" ] ||
            fail "estimator helper override is not executable: $estimator_override"
        "$estimator_override" \
            "$candidate_targets" "$retained_targets" "$ignored_roots" \
            >"$helper_output" ||
            fail "estimator helper override failed"
    else
        [ "$root" = / ] ||
            fail "the live estimator helper requires GUIX_RETENTION_ROOT=/"
        [ -r "$estimator_scheme" ] ||
            fail "estimator Scheme helper is missing: $estimator_scheme"
        [ -x "$estimator_guix" ] ||
            fail "current Guix is unavailable: $estimator_guix"
        "$estimator_guix" repl -q -- "$estimator_scheme" \
            "$candidate_targets" "$retained_targets" "$ignored_roots" \
            >"$helper_output" ||
            fail "read-only Guix store estimator failed"
    fi
    validate_helper_output "$helper_output"
}

profile_distinct_count() {
    pdc_kind=$1
    awk -F '\t' -v kind="$pdc_kind" '
        $1 == kind { seen[$3] = 1 }
        END { for (target in seen) count++; print count + 0 }
    ' "$inventory"
}

policy_link_count() {
    plc_kind=$1
    plc_record=$2
    awk -F '\t' -v kind="$plc_kind" -v record="$plc_record" '
        $1 == record && $2 == kind { count++ }
        END { print count + 0 }
    ' "$policy_rows"
}

print_estimate() {
    printf 'schema\tp5.1-estimate/v1\n'
    printf 'mode\tread-only\n'
    printf 'policy\tadditional-distinct-closures\t5\n'
    for pe_kind in system home pull; do
        pe_links=$(count_kind "$inventory" "$pe_kind")
        pe_distinct=$(profile_distinct_count "$pe_kind")
        pe_current=$(awk -F '\t' -v kind="$pe_kind" '
            $1 == kind { print $2 "\t" $3 }
        ' "$currents")
        printf 'profile\t%s\t%s\t%s\t%s\n' \
            "$pe_kind" "$pe_links" "$pe_distinct" "$pe_current"
        printf 'summary\t%s\tretained-links\t%s\n' \
            "$pe_kind" "$(policy_link_count "$pe_kind" retain)"
        printf 'summary\t%s\tcandidate-links\t%s\n' \
            "$pe_kind" "$(policy_link_count "$pe_kind" candidate)"
    done
    cat "$policy_rows"
    cat "$helper_output"
    pe_fingerprint=$(
        {
            cat "$snapshot_before"
            cat "$policy_rows"
            cat "$helper_output"
        } | sha256sum | awk '{ print $1 }'
    )
    printf 'fingerprint\t%s\n' "$pe_fingerprint"
    printf 'status\tPASS\n'
}

count_kind() {
    ck_file=$1
    ck_kind=$2
    awk -F '\t' -v kind="$ck_kind" '$1 == kind { n++ } END { print n + 0 }' "$ck_file"
}

comma_candidates() {
    cc_kind=$1
    awk -F '\t' -v kind="$cc_kind" '$1 == kind { print $2 }' "$candidates" |
        sort -n | paste -sd, -
}

print_summary() {
    printf 'System generations: %s\n' "$(count_kind "$inventory" system)"
    printf 'Home generations: %s\n' "$(count_kind "$inventory" home)"
    printf 'Pull generations: %s\n' "$(count_kind "$inventory" pull)"
    awk -F '\t' '{ printf "Current %s: generation %s -> %s\n", $1, $2, $3 }' "$currents"
    printf 'Booted System: %s\n' "$booted_target"
}

print_candidates() {
    pc_system=$(comma_candidates system)
    pc_home=$(comma_candidates home)
    pc_pull=$(comma_candidates pull)
    printf 'System duplicate candidates: %s\n' "${pc_system:-none}"
    printf 'Home duplicate candidates: %s\n' "${pc_home:-none}"
    printf 'Pull duplicate candidates: %s\n' "${pc_pull:-none}"
}

print_plan_command() {
    ppc_kind=$1
    ppc_generations=$(comma_candidates "$ppc_kind")
    [ -n "$ppc_generations" ] || return 0
    case $ppc_kind in
        system)
            printf 'System deletion held: candidates %s require a configuration-aware GRUB design; no command emitted\n' \
                "$ppc_generations"
            ;;
        home)
            printf 'Would run locally after review: %s home delete-generations %s\n' \
                "$retention_home/.config/guix/current/bin/guix" "$ppc_generations"
            ;;
        pull)
            printf 'Would run locally after review: %s pull --delete-generations=%s\n' \
                "$retention_home/.config/guix/current/bin/guix" "$ppc_generations"
            ;;
    esac
}

role_field() {
    rf_kind=$1
    rf_role=$2
    rf_field=$3
    rf_result=$(awk -F '\t' -v kind="$rf_kind" -v role="$rf_role" -v field="$rf_field" '
        $1 == kind && $4 == role { print $field }
    ' "$normalized_pins")
    rf_count=$(printf '%s\n' "$rf_result" | awk 'NF { n++ } END { print n + 0 }')
    [ "$rf_count" -eq 1 ] ||
        fail "$rf_kind requires exactly one $rf_role pin"
    printf '%s\n' "$rf_result"
}

rollback_drill() {
    rd_grub=$(root_path /boot/grub/grub.cfg)
    [ -r "$rd_grub" ] || fail "GRUB configuration is not readable: $rd_grub"

    while IFS="$tab" read -r rd_kind rd_generation rd_target rd_role rd_reason; do
        : "$rd_role" "$rd_reason"
        rd_physical=$(root_path "$rd_target")
        case $rd_kind in
            system)
                [ -e "$rd_physical/kernel" ] ||
                    fail "System $rd_generation is missing its kernel"
                [ -e "$rd_physical/initrd" ] ||
                    fail "System $rd_generation is missing its initrd"
                rd_current=$(awk -F '\t' '$1 == "system" { print $2 }' "$currents")
                if [ "$rd_generation" != "$rd_current" ]; then
                    grep -F "system-$rd_generation-link" "$rd_grub" >/dev/null ||
                        fail "GRUB is missing System generation $rd_generation"
                fi
                ;;
            home)
                [ -e "$rd_physical/activate" ] ||
                    fail "Home $rd_generation is missing its activation program"
                ;;
            pull)
                [ -x "$rd_physical/bin/guix" ] ||
                    fail "Pull $rd_generation is missing an executable Guix"
                "$rd_physical/bin/guix" --version >/dev/null 2>&1 ||
                    fail "Pull $rd_generation Guix does not run --version"
                ;;
        esac
    done <"$normalized_pins"

    rd_system=$(role_field system promotion-rollback 2)
    rd_home=$(role_field home promotion-rollback 2)
    rd_pull=$(role_field pull promotion-rollback 2)
    rd_recovery_guix=$(role_field pull promotion-rollback 3)/bin/guix
    rd_older_system=$(role_field system preferred-rollback 2)
    rd_older_home=$(role_field home preferred-rollback 2)
    rd_older_pull=$(role_field pull preferred-rollback 2)
    printf '%s\n' 'Rollback drill: PASS (read-only artifact/command-path rehearsal; no generation was switched)'
    printf 'System recovery command: /run/setuid-programs/sudo %s system switch-generation %s && /run/current-system/profile/sbin/reboot\n' \
        "$rd_recovery_guix" "$rd_system"
    printf 'Home recovery command: %s home switch-generation %s\n' \
        "$rd_recovery_guix" "$rd_home"
    printf 'Pull recovery command: %s pull --switch-generation=%s\n' \
        "$rd_recovery_guix" "$rd_pull"
    printf 'Older recovery tier: System %s; Home %s; pull %s\n' \
        "$rd_older_system" "$rd_older_home" "$rd_older_pull"
    printf '%s\n' 'Home warning: generation rollback does not revert live repository symlinks; restore the matching source checkpoint first.'
}

prepare_state

case $action in
    inventory)
        printf '%s\n' 'Inventory (kind, generation, canonical store target):'
        cat "$inventory"
        print_summary
        printf '%s\n' 'Protected pins (kind, generation, target, role, reason):'
        cat "$normalized_pins"
        ;;
    plan)
        printf '%s\n' 'Retention plan: READ-ONLY; duplicate links only; no garbage collection'
        print_summary
        print_candidates
        print_plan_command system
        print_plan_command home
        print_plan_command pull
        printf '%s\n' 'Apply is intentionally unavailable; rerun plan after review and implement deletion only in a separately tested change.'
        ;;
    estimate)
        snapshot_generation_state "$snapshot_before"
        prepare_estimate_policy
        run_estimator_helper
        snapshot_generation_state "$snapshot_after"
        cmp -s "$snapshot_before" "$snapshot_after" ||
            fail "generation, pointer, or pin state changed during estimation"
        print_estimate
        ;;
    verify)
        print_summary
        print_candidates
        printf '%s\n' 'Retention verification: PASS'
        ;;
    rollback-drill)
        rollback_drill
        ;;
esac
