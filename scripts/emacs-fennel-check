#!/bin/sh

set -eu

check_failed=0

record_failure() {
    printf 'emacs-fennel-check: %s\n' "$1" >&2
    check_failed=1
}

fail() {
    record_failure "$1"
    exit 1
}

usage() {
    printf 'usage: %s [REPOSITORY]\n' "$0" >&2
    exit 64
}

case $# in
    0) repository_input=$(dirname "$0")/.. ;;
    1) repository_input=$1 ;;
    *) usage ;;
esac

if ! repo=$(CDPATH='' cd -- "$repository_input" 2>/dev/null && pwd -P); then
    printf 'emacs-fennel-check: repository is not a directory: %s\n' \
        "$repository_input" >&2
    exit 66
fi

home_profile=${SK_EMACS_CHECK_HOME_PROFILE:-}
system_profile=${SK_EMACS_CHECK_SYSTEM_PROFILE:-}
guix=${GUIX:-}
caller_cache=${XDG_CACHE_HOME:-}

for pair in "Home:$home_profile" "System:$system_profile"; do
    label=${pair%%:*}
    profile=${pair#*:}
    case $profile in
        /*) ;;
        *) fail "$label profile must be an absolute path" ;;
    esac
    [ -d "$profile" ] || fail "$label profile is not a directory: $profile"
done

case $guix in
    /*) ;;
    *) fail 'GUIX must name the absolute pinned Guix executable' ;;
esac
[ -x "$guix" ] || fail "pinned Guix is not executable: $guix"

home_emacs=$home_profile/bin/emacs
[ -x "$home_emacs" ] || \
    fail "candidate Home Emacs is not executable: $home_emacs"

for path in \
    "$repo/emacs/early-init.el" \
    "$repo/emacs/init.el" \
    "$repo/emacs/lisp/sk-fennel.el" \
    "$repo/fixtures/fennel/.projectile" \
    "$repo/fixtures/fennel/Makefile" \
    "$repo/fixtures/fennel/flsproject.fnl" \
    "$repo/fixtures/fennel/src/sk/fixture/main.fnl" \
    "$repo/fixtures/fennel/src/sk/fixture/math.fnl" \
    "$repo/fixtures/fennel/src/sk/fixture/macros.fnl" \
    "$repo/fixtures/fennel/test/sk/fixture/main-test.fnl" \
    "$repo/guix/channels.scm" \
    "$repo/guix/manifests/fennel.scm" \
    "$repo/guix/modules/sk/development-tiers.scm" \
    "$repo/scripts/fennel-project" \
    "$repo/scripts/guix-lisp-shell" \
    "$repo/tests/emacs/fennel-backend-check.el"; do
    [ -r "$path" ] || fail "unreadable candidate input: $path"
done

for path in "$repo/scripts/fennel-project" \
    "$repo/scripts/guix-lisp-shell"; do
    [ -x "$path" ] || fail "candidate wrapper is not executable: $path"
done

candidate_path=$home_profile/bin:$system_profile/bin:$system_profile/sbin
candidate_emacsloadpath=$home_profile/share/emacs/site-lisp:$system_profile/share/emacs/site-lisp:
export PATH="$candidate_path"

for command in chmod cksum cp dirname env find git kill ln mkdir mktemp rm \
    sed sleep sort timeout tr; do
    command -v "$command" >/dev/null 2>&1 || \
        fail "missing candidate command: $command"
done

fixture_state() {
    (
        cd "$repo/fixtures/fennel"
        {
            find . -type d -print
            find . -type f -exec cksum {} \;
        } | LC_ALL=C sort
    )
}

repository_state() {
    printf '%s\n' '== status =='
    git -C "$repo" status --porcelain=v1 --untracked-files=all
    printf '%s\n' '== worktree diff =='
    git -C "$repo" diff --no-ext-diff --binary
    printf '%s\n' '== index diff =='
    git -C "$repo" diff --cached --no-ext-diff --binary
    printf '%s\n' '== untracked content =='
    git -C "$repo" ls-files --others --exclude-standard | sort |
        while IFS= read -r relative; do
            [ -n "$relative" ] || continue
            cksum "$repo/$relative" || printf 'UNREADABLE %s\n' "$relative"
        done
}

fixture_before=$(fixture_state)
repository_before=$(repository_state)

sandbox=$(mktemp -d "${TMPDIR:-/tmp}/sk-emacs-fennel-check.XXXXXX")
sandbox=$(CDPATH='' cd "$sandbox" && pwd -P)

sandbox_processes() {
    for process_directory in /proc/[0-9]*; do
        [ -r "$process_directory/cmdline" ] || continue
        pid=${process_directory##*/}
        command_line=$(tr '\000' '\n' <"$process_directory/cmdline" 2>/dev/null) || \
            continue
        case $command_line in
            *"$sandbox"*) printf '%s\n' "$pid" ;;
        esac
    done
}

signal_sandbox_processes() {
    signal=$1
    sandbox_processes | while IFS= read -r pid; do
        kill "-$signal" "$pid" 2>/dev/null || true
    done
}

cleanup() {
    set +e
    processes=$(sandbox_processes)
    if [ -n "$processes" ]; then
        signal_sandbox_processes TERM
        attempt=0
        while [ "$attempt" -lt 50 ] && [ -n "$(sandbox_processes)" ]; do
            sleep 0.1
            attempt=$((attempt + 1))
        done
        if [ -n "$(sandbox_processes)" ]; then
            signal_sandbox_processes KILL
            sleep 0.1
        fi
    fi
    rm -rf -- "$sandbox"
}
trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

source_root=$sandbox/source
second_project=$sandbox/second-project
isolated_home=$sandbox/home
isolated_tmp=$sandbox/tmp
isolated_cache=$sandbox/xdg/cache
isolated_config=$sandbox/xdg/config
isolated_data=$sandbox/xdg/data
isolated_state=$sandbox/xdg/state
isolated_runtime=$sandbox/xdg/runtime

mkdir -p "$source_root/fixtures/fennel" "$second_project" \
    "$source_root/guix/manifests" "$source_root/guix/modules/sk" \
    "$source_root/scripts" "$source_root/tests/emacs" \
    "$isolated_home/.emacs.d" "$isolated_tmp" "$isolated_cache" \
    "$isolated_config" "$isolated_data" "$isolated_state" \
    "$isolated_runtime" "$isolated_home/.guix-home"
chmod 700 "$sandbox" "$isolated_home" "$isolated_tmp" "$isolated_runtime"

# Model the production Guix Home identity inside the isolated HOME.  The
# candidate profile remains immutable; only the profile link and caches live
# below this checker's private sandbox.
ln -s "$home_profile" "$isolated_home/.guix-home/profile"

case $caller_cache in
    /*)
        if [ -d "$caller_cache/guix" ]; then
            ln -s "$caller_cache/guix" "$isolated_cache/guix"
        fi
        ;;
esac

cp -R "$repo/emacs" "$source_root/emacs"
cp -R "$repo/fixtures/fennel/." "$source_root/fixtures/fennel/"
cp -R "$repo/fixtures/fennel/." "$second_project/"
cp "$repo/guix/channels.scm" "$source_root/guix/channels.scm"
cp "$repo/guix/manifests/fennel.scm" "$source_root/guix/manifests/fennel.scm"
cp "$repo/guix/modules/sk/development-tiers.scm" \
    "$source_root/guix/modules/sk/development-tiers.scm"
cp "$repo/scripts/guix-lisp-shell" "$source_root/scripts/guix-lisp-shell"
cp "$repo/scripts/fennel-project" "$source_root/scripts/fennel-project"
cp "$repo/tests/emacs/fennel-backend-check.el" \
    "$source_root/tests/emacs/fennel-backend-check.el"

phase_processes_gone() {
    pids_file=$1
    details_file=$2
    if [ ! -s "$pids_file" ]; then
        record_failure "phase recorded no live descendants: $pids_file"
        return
    fi
    while IFS= read -r pid; do
        case $pid in
            ''|*[!0-9]*)
                record_failure "invalid recorded descendant PID: $pid"
                ;;
        esac
    done <"$pids_file"
    attempt=0
    while [ "$attempt" -lt 100 ]; do
        survivors=
        while IFS= read -r pid; do
            case $pid in
                ''|*[!0-9]*) continue ;;
            esac
            if kill -0 "$pid" 2>/dev/null; then
                survivors="$survivors $pid"
            fi
        done <"$pids_file"
        [ -n "$survivors" ] || return 0
        sleep 0.1
        attempt=$((attempt + 1))
    done
    [ ! -r "$details_file" ] || sed -n '1,200p' "$details_file" >&2
    record_failure "OS descendants survived editor cleanup:$survivors"
}

run_editor() {
    phase=$1
    pids_file=$isolated_state/$phase-descendant-pids
    details_file=$isolated_state/$phase-descendant-details
    failure_marker=$isolated_state/$phase-triggered
    rm -f -- "$pids_file" "$details_file" "$failure_marker"

    set +e
    env -i \
        HOME="$isolated_home" \
        TMPDIR="$isolated_tmp" \
        XDG_CACHE_HOME="$isolated_cache" \
        XDG_CONFIG_HOME="$isolated_config" \
        XDG_DATA_HOME="$isolated_data" \
        XDG_STATE_HOME="$isolated_state" \
        XDG_RUNTIME_DIR="$isolated_runtime" \
        GUIX="$guix" \
        PATH="$candidate_path" \
        EMACSLOADPATH="$candidate_emacsloadpath" \
        LANG=en_US.utf8 \
        LC_ALL=en_US.utf8 \
        TZ=UTC \
        SK_EMACS_FENNEL_PHASE="$phase" \
        SK_EMACS_FENNEL_SOURCE_ROOT="$source_root" \
        SK_EMACS_FENNEL_SANDBOX_ROOT="$sandbox" \
        SK_EMACS_FENNEL_SECOND_PROJECT="$second_project" \
        SK_EMACS_FENNEL_DESCENDANT_PIDS="$pids_file" \
        SK_EMACS_FENNEL_DESCENDANT_DETAILS="$details_file" \
        SK_EMACS_FENNEL_FAILURE_MARKER="$failure_marker" \
        timeout --signal=TERM --kill-after=10 600 \
        "$home_emacs" --batch -Q \
        --eval '(setq user-emacs-directory (file-name-as-directory (expand-file-name ".emacs.d" (getenv "HOME"))))' \
        --load "$source_root/emacs/early-init.el" \
        --eval '(setq flycheck-check-syntax-automatically nil)' \
        --load "$source_root/emacs/init.el" \
        --eval '(run-hooks (quote after-init-hook))' \
        --load "$source_root/tests/emacs/fennel-backend-check.el"
    editor_status=$?
    set -e

    case $phase in
        success)
            [ "$editor_status" -eq 0 ] || \
                record_failure "connected success phase exited $editor_status"
            [ ! -e "$failure_marker" ] || \
                record_failure 'success phase created deliberate-failure marker'
            ;;
        deliberate-failure)
            [ "$editor_status" -ne 0 ] || \
                record_failure 'deliberate connected failure unexpectedly passed'
            [ -s "$failure_marker" ] || \
                record_failure 'deliberate failure did not reach its live checkpoint'
            ;;
        *) record_failure "unknown checker phase: $phase" ;;
    esac

    phase_processes_gone "$pids_file" "$details_file"
    processes=$(sandbox_processes)
    [ -z "$processes" ] || record_failure \
        "$phase sandbox processes survived editor cleanup: $processes"
}

run_editor success
[ "$check_failed" -ne 0 ] || run_editor deliberate-failure

fixture_after=$(fixture_state)
repository_after=$(repository_state)
[ "$fixture_after" = "$fixture_before" ] || \
    record_failure 'source Fennel fixture changed during isolated editor checks'
[ "$repository_after" = "$repository_before" ] || \
    record_failure 'repository state changed during isolated editor checks'

for project in "$source_root/fixtures/fennel" "$second_project"; do
    for artifact in .fennel .fnx .luarocks target; do
        [ ! -e "$project/$artifact" ] || \
            record_failure \
                "connected tooling leaked project state: $project/$artifact"
    done
done

[ "$check_failed" -eq 0 ] || exit 1

printf '%s\n' 'emacs-fennel-check: deliberate failure cleanup PASS'
printf '%s\n' 'emacs-fennel-check: PASS'
