#!/bin/sh
set -eu

usage() {
    printf 'usage: %s system|home [--print] [GUIX-OPTION ...]\n' "$0" >&2
    exit 64
}

[ "$#" -ge 1 ] || usage

mode=$1
shift

print_only=0
if [ "${1:-}" = "--print" ]; then
    print_only=1
    shift
fi

if [ "$print_only" -eq 1 ] && [ "$#" -ne 0 ]; then
    usage
fi

home=${HOME:?HOME must be set}
script_dir=$(CDPATH='' cd "$(dirname "$0")" && pwd -P)
entrypoints_check="$script_dir/guix-entrypoints"
home_links_preflight="$script_dir/guix-home-links-preflight.scm"
frontend_input=${SK_GUIX_FRONTEND_PROFILE:-$home/.config/guix/current}
channels="$home/.config/guix/channels.scm"
privileged_sudo=/run/setuid-programs/sudo
substitute_urls='https://ci.guix.gnu.org https://bordeaux.guix.gnu.org https://substitutes.nonguix.org'

case "$mode" in
    system)
        source="$home/.config/guix/systems/guixpc.scm"
        ;;
    home)
        source="$home/.config/guix/home.scm"
        ;;
    *)
        usage
        ;;
esac

if [ ! -x "$entrypoints_check" ]; then
    printf 'guix-reconfigure: entrypoint checker is not executable: %s\n' \
        "$entrypoints_check" >&2
    exit 1
fi

"$entrypoints_check" check

case $frontend_input in
    /*) ;;
    *)
        printf 'guix-reconfigure: frontend profile must be absolute: %s\n' \
            "$frontend_input" >&2
        exit 1
        ;;
esac

guix_profile=$(readlink -f "$frontend_input") || {
    printf 'guix-reconfigure: cannot resolve frontend profile: %s\n' \
        "$frontend_input" >&2
    exit 1
}
guix=$guix_profile/bin/guix
if [ ! -x "$guix" ]; then
    printf 'guix-reconfigure: frontend Guix is not executable: %s\n' "$guix" >&2
    exit 1
fi

if [ ! -r "$channels" ]; then
    printf 'guix-reconfigure: pinned channels are not readable: %s\n' \
        "$channels" >&2
    exit 1
fi

if [ ! -r "$source" ]; then
    printf 'guix-reconfigure: configuration source is not readable: %s\n' "$source" >&2
    exit 1
fi

if [ "$mode" = system ] && [ ! -x "$privileged_sudo" ]; then
    printf 'guix-reconfigure: privileged sudo is not executable: %s\n' "$privileged_sudo" >&2
    exit 1
fi

guix_resolved=$guix_profile/bin/guix
source_resolved=$(readlink -f "$source")
if [ -z "$guix_profile" ] || [ ! -x "$guix_resolved" ]; then
    printf 'guix-reconfigure: could not freeze frontend Guix profile: %s\n' \
        "$frontend_input" >&2
    exit 1
fi

if [ "$mode" = home ]; then
    guile=${SK_GUIX_RECONFIGURE_GUILE:-/run/current-system/profile/bin/guile}
    guile_resolved=$(readlink -f "$guile")
    if [ ! -r "$home_links_preflight" ]; then
        printf 'guix-reconfigure: Home link preflight is not readable: %s\n' \
            "$home_links_preflight" >&2
        exit 1
    fi
    if [ -z "$guile_resolved" ] || [ ! -x "$guile_resolved" ]; then
        printf 'guix-reconfigure: canonical Guile is unavailable for Home preflight: %s\n' \
            "$guile" >&2
        exit 1
    fi
    GUILE_AUTO_COMPILE=0 "$guile_resolved" --no-auto-compile \
        "$home_links_preflight" "$script_dir/.."
fi
expected_channels=$(
    awk '
        function quoted(line, value) {
            value = line
            if (value !~ /"/) return ""
            sub(/^[^"]*"/, "", value)
            sub(/".*/, "", value)
            return value
        }
        function emit() {
            if (name == "") return
            if (url == "") url = "<missing>"
            if (branch == "") branch = "<missing>"
            if (commit == "") commit = "<missing>"
            if (introduction == "") introduction = "<missing>"
            if (signer == "") signer = "<missing>"
            print name, url, branch, commit, introduction, signer
            name = url = branch = commit = introduction = signer = ""
        }
        /\(name '\''[^)]*\)/ {
            emit()
            name = $0
            sub(/^.*\(name '\''/, "", name)
            sub(/\).*/, "", name)
            next
        }
        /\(url "[^"]*"\)/ {
            url = quoted($0)
            next
        }
        /\(branch "[^"]*"\)/ {
            branch = quoted($0)
            next
        }
        /\(commit "[^"]*"\)/ && name != "" {
            commit = $0
            sub(/^.*\(commit "/, "", commit)
            sub(/".*/, "", commit)
            next
        }
        /\(make-channel-introduction/ {
            introduction_pending = 1
            value = quoted($0)
            if (value != "") {
                introduction = value
                introduction_pending = 0
            }
            next
        }
        introduction_pending {
            value = quoted($0)
            if (value != "") {
                introduction = value
                introduction_pending = 0
            }
            next
        }
        /\(openpgp-fingerprint/ {
            signer_pending = 1
            value = quoted($0)
            if (value != "") {
                signer = value
                signer_pending = 0
                gsub(/[[:space:]]/, "", signer)
            }
            next
        }
        signer_pending {
            value = quoted($0)
            if (value != "") {
                signer = value
                signer_pending = 0
                gsub(/[[:space:]]/, "", signer)
            }
        }
        END { emit() }
    ' "$channels" | sort
)
actual_channels=$(
    "$guix_resolved" describe --format=recutils |
        awk '
            function emit() {
                if (name == "") return
                if (url == "") url = "<missing>"
                if (branch == "") branch = "<missing>"
                if (commit == "") commit = "<missing>"
                if (introduction == "") introduction = "<missing>"
                if (signer == "") signer = "<missing>"
                print name, url, branch, commit, introduction, signer
                name = url = branch = commit = introduction = signer = ""
            }
            $1 == "name:" { emit(); name = $2; next }
            $1 == "url:" { url = $2; next }
            $1 == "branch:" { branch = $2; next }
            $1 == "commit:" { commit = $2; next }
            $1 == "introductioncommit:" { introduction = $2; next }
            $1 == "introductionsigner:" {
                signer = $0
                sub(/^[^:]*:[[:space:]]*/, "", signer)
                gsub(/[[:space:]]/, "", signer)
                next
            }
            NF == 0 { emit(); next }
            END { emit() }
        ' |
        sort
)

if [ -z "$expected_channels" ] || [ "$actual_channels" != "$expected_channels" ]; then
    printf '%s\n' \
        'guix-reconfigure: current Guix channels differ from the repository lock' >&2
    printf '%s\n' 'expected:' "$expected_channels" 'actual:' "$actual_channels" >&2
    printf 'guix-reconfigure: run %s before activation\n' \
        "$script_dir/guix-build-gate" >&2
    printf 'guix-reconfigure: then pull exactly %s\n' "$channels" >&2
    exit 1
fi

guix_revision=$(
    "$guix_resolved" describe --format=recutils |
        awk '
            $1 == "name:" { guix_channel = ($2 == "guix"); next }
            guix_channel && $1 == "commit:" { print $2; exit }
        '
)

if [ -z "$guix_resolved" ] || [ -z "$source_resolved" ] || [ -z "$guix_revision" ]; then
    printf 'guix-reconfigure: could not establish Guix provenance\n' >&2
    exit 1
fi

case $guix_revision in
    *[!0-9a-f]*)
        printf 'guix-reconfigure: invalid Guix revision: %s\n' \
            "$guix_revision" >&2
        exit 1
        ;;
esac

if [ "${#guix_revision}" -ne 40 ]; then
    printf 'guix-reconfigure: invalid Guix revision length: %s\n' \
        "$guix_revision" >&2
    exit 1
fi

printf 'guix-reconfigure: mode=%s\n' "$mode"
printf 'guix-reconfigure: guix=%s\n' "$guix"
printf 'guix-reconfigure: guix-resolved=%s\n' "$guix_resolved"
printf 'guix-reconfigure: guix-revision=%s\n' "$guix_revision"
printf 'guix-reconfigure: source=%s\n' "$source"
printf 'guix-reconfigure: source-resolved=%s\n' "$source_resolved"
printf 'guix-reconfigure: substitute-urls=%s\n' "$substitute_urls"

if [ "$mode" = home ]; then
    printf 'guix-reconfigure: preflight-guile=%s\n' "$guile_resolved"
fi

if [ "$mode" = system ]; then
    printf 'guix-reconfigure: sudo=%s\n' "$privileged_sudo"
    printf 'guix-reconfigure: sudo-resolved=%s\n' "$(readlink -f "$privileged_sudo")"
fi

if [ "$print_only" -eq 1 ]; then
    exit 0
fi

if [ "$mode" = system ]; then
    exec "$privileged_sudo" "$guix_resolved" system reconfigure "$source_resolved" \
        --substitute-urls="$substitute_urls" "$@"
else
    exec "$guix_resolved" home reconfigure "$source_resolved" \
        --substitute-urls="$substitute_urls" "$@"
fi
